# Public site URL (canonical, sitemap, RSS, Open Graph)
PUBLIC_SITE_URL=https://digidevs.no

# Google Analytics 4 — Measurement ID from Admin → Data streams (format G-XXXXXXXXXX)
# Loaded only when CookieYes is also set (GCM v2 + Basic order). Without PUBLIC_COOKIEYES_WEBSITE_KEY, GA is not injected.
# PUBLIC_GA_MEASUREMENT_ID=

# CookieYes — site key from Dashboard → Advanced settings → Get installation code (value in CDN URL …/client_data/<KEY>/script.js)
# In CookieYes: enable "Support GCM" (Basic Consent Mode); map Google Analytics to the Analytics category; then verify GCM in the dashboard.
# Other third-party scripts: register cookies in CookieYes, then use manual blocking (e.g. type="text/plain" + CookieYes data attributes) or inject only after the user accepts that category.
# PUBLIC_COOKIEYES_WEBSITE_KEY=

# Sanity Content Lake (same project ID as in sanity-studio/.env next to this file)
# Required for `pnpm build` / prerender: blog routes and RSS query Sanity. Set the same in Vercel (or your CI) env.
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01

# Offers — password protection. When set, visitors must sign in at `/offers/login` (HttpOnly session cookie).
# Optional legacy bypass for tools: same value as `?key=` or `x-offer-key` header.
# OFFER_ACCESS_PASSWORD=
# OFFER_ACCESS_SECRET=

# Local PDF generation (optional): path to Chromium when not on Vercel (otherwise Playwright uses Chrome channel).
# CHROMIUM_EXECUTABLE_PATH=

# Optional: only if the dataset is private or you use preview APIs
# SANITY_API_READ_TOKEN=

# Required on the server to set the customer-offer password from the internal offer UI (PATCH offer in Sanity). Never expose to the client.
# Create an Editor token at sanity.io/manage → API → Tokens.
# SANITY_API_WRITE_TOKEN=

# Customer offer pages (/offer/p/...) — signs the HttpOnly `offer_viewer` session cookie (separate from OFFER_ACCESS_PASSWORD / offer_gate).
# Generate a long random string; set in Vercel for production.
# OFFER_VIEWER_SIGNING_SECRET=

# Brevo transactional email (Brevo may email “verify a new IP” when the server’s egress IP changes — approve it in the Brevo dashboard)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=no-reply@digidevs.no
BREVO_SENDER_NAME=digiDEVS
BREVO_RECIPIENT_EMAIL=contact@digidevs.no
