---
import { Image } from "astro:assets";
import MarketingIcon from "../icons/MarketingIcon";
import DigiDevsWordmark from "../brand/DigiDevsWordmark.astro";
import type { Locale } from "../../i18n/locales";
import { useTranslations } from "../../i18n/utils";
import digidevsMountains from "../../assets/digidevs-mountains.png";
import splitVidilice from "../../assets/split-vidilice.jpg";

interface Props {
	lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const contactFormLoading = t("contact.form_loading");
const contactFormSuccess = t("contact.form_success");
const contactFormError = t("contact.form_error");
const contactFormRateLimited = t("contact.form_rate_limited");
const contactFormSubmit = t("contact.form_submit");

---

<main class="relative min-h-screen overflow-hidden pb-20 pt-24 md:pt-28">
	<!-- Background -->
	<div class="absolute inset-0 -z-20">
		<Image
			src={digidevsMountains}
			alt=""
			aria-hidden="true"
			width={digidevsMountains.width}
			height={digidevsMountains.height}
			layout="full-width"
			fit="cover"
			position="center"
			sizes="100vw"
			quality="high"
			format="avif"
			priority
			decoding="sync"
			class="absolute inset-0 z-0 size-full object-cover object-center opacity-30 mix-blend-luminosity"
		/>
		<div
			class="absolute inset-0 bg-linear-to-b from-surface via-surface/80 to-surface"
			aria-hidden="true"
		>
		</div>
	</div>
	<div
		class="pointer-events-none absolute -left-[10%] top-[-20%] -z-10 size-[600px] rounded-full bg-secondary aurora-blur"
		aria-hidden="true"
	>
	</div>
	<div
		class="pointer-events-none absolute bottom-[10%] -right-[5%] -z-10 size-[400px] rounded-full bg-tertiary aurora-blur"
		aria-hidden="true"
	>
	</div>

	<div
		class="relative mx-auto grid max-w-screen-2xl grid-cols-1 gap-8 px-8 md:gap-12 lg:grid-cols-12 lg:gap-16"
	>
		<section class="mb-6 mt-12 md:mb-12 lg:mb-20 lg:col-span-12">
			<h1
				class="font-headline mb-8 text-5xl font-bold leading-[0.95] tracking-editorial text-on-surface md:text-6xl lg:text-7xl"
			>
				{t("contact.hero_line1")}{" "}
				<br />
				<DigiDevsWordmark class="text-primary-container" />
			</h1>
			<div class="grid grid-cols-1 lg:grid-cols-12">
				<p
					class="font-body text-lg leading-relaxed text-on-surface-variant md:text-xl lg:col-span-5 lg:col-start-7"
				>
					{t("contact.hero_blurb")}
				</p>
			</div>
		</section>

		<section
			class="grid gap-6 lg:col-span-12 lg:grid-cols-2"
			aria-labelledby="contact-services-heading"
		>
			<div class="rounded-xl border border-border bg-surface-container-low p-8 backdrop-blur-md">
				<h2
					id="contact-services-heading"
					class="font-headline mb-4 text-2xl font-bold text-on-surface md:text-3xl"
				>
					{t("contact.services_heading")}
				</h2>
				<p class="font-body leading-relaxed text-on-surface-variant">
					{t("contact.services_body")}
				</p>
			</div>
			<div class="rounded-xl border border-border bg-surface-container-low p-8 backdrop-blur-md">
				<h2 class="font-headline mb-4 text-2xl font-bold text-on-surface md:text-3xl">
					{t("contact.expect_heading")}
				</h2>
				<p class="font-body leading-relaxed text-on-surface-variant">
					{t("contact.expect_body")}
				</p>
			</div>
		</section>

		<section
			id="contact-form"
			class="scroll-mt-28 lg:col-span-7"
			tabindex="-1"
			aria-labelledby="contact-form-heading"
		>
			<div
				class="rounded-xl border border-border bg-surface-container-low p-8 backdrop-blur-md md:p-12"
			>
				<h2 id="contact-form-heading" class="font-headline mb-8 text-3xl font-bold text-on-surface">
					{t("contact.form_heading")}
				</h2>
				<!-- data-astro-reload: after POST, Astro does a full navigation so the handler runs (form uses server route + client status script). -->
				<form
					class="relative space-y-8"
					method="post"
					action="/api/contact"
					data-astro-reload
					data-contact-form
				>
					<div class="grid grid-cols-1 gap-8 md:grid-cols-2">
						<div class="relative">
							<label
								class="font-label mb-2 block text-xs uppercase tracking-widest text-secondary-focus"
								for="contact-name"
							>
								{t("contact.form_name_label")}
							</label>
							<input
								class="input-editorial w-full rounded-lg border-none p-4 placeholder:text-on-surface-variant/40"
								id="contact-name"
								name="name"
								type="text"
								autocomplete="name"
								placeholder={t("contact.form_name_placeholder")}
							/>
						</div>
						<div class="relative">
							<label
								class="font-label mb-2 block text-xs uppercase tracking-widest text-secondary-focus"
								for="contact-company"
							>
								{t("contact.form_company_label")}
							</label>
							<input
								class="input-editorial w-full rounded-lg border-none p-4 placeholder:text-on-surface-variant/40"
								id="contact-company"
								name="company"
								type="text"
								autocomplete="organization"
								placeholder={t("contact.form_company_placeholder")}
							/>
						</div>
					</div>
					<div class="relative">
						<label
							class="font-label mb-2 block text-xs uppercase tracking-widest text-secondary-focus"
							for="contact-email"
						>
							{t("contact.form_email_label")}
						</label>
						<input
							class="input-editorial w-full rounded-lg border-none p-4 placeholder:text-on-surface-variant/40"
							id="contact-email"
							name="email"
							type="email"
							autocomplete="email"
							required
							placeholder={t("contact.form_email_placeholder")}
						/>
					</div>
					<div class="relative">
						<label
							class="font-label mb-2 block text-xs uppercase tracking-widest text-secondary-focus"
							for="contact-brief"
						>
							{t("contact.form_brief_label")}
						</label>
						<textarea
							class="input-editorial w-full resize-none rounded-lg border-none p-4 placeholder:text-on-surface-variant/40"
							id="contact-brief"
							name="message"
							rows={5}
							placeholder={t("contact.form_brief_placeholder")}
						></textarea>
					</div>
					<!-- Honeypot: must stay empty; hidden from view and assistive tech -->
					<div class="absolute -left-[9999px] h-px w-px overflow-hidden" aria-hidden="true">
						<label for="contact-hp">Leave blank</label>
						<input
							id="contact-hp"
							type="text"
							name="contact_hp"
							tabindex="-1"
							autocomplete="off"
							value=""
						/>
					</div>
					<button
						class="font-headline w-full rounded-full bg-primary-container px-12 py-5 text-lg font-bold text-on-primary-container shadow-lg shadow-primary-container/10 transition-all hover:brightness-110 active:scale-95 disabled:pointer-events-none disabled:opacity-60 md:w-auto"
						type="submit"
						data-contact-submit
					>
						{t("contact.form_submit")}
					</button>
					<p
						class="hidden text-sm leading-relaxed"
						data-contact-feedback
						role="status"
						aria-live="polite"
					></p>
				</form>
			</div>
		</section>

		<aside class="flex flex-col justify-between py-4 lg:col-span-5">
			<div class="space-y-16">
				<div>
					<h2
						class="font-label mb-6 flex items-center gap-2 text-xs uppercase tracking-aside text-tertiary-light"
					>
						<MarketingIcon name="alternate_email" size={16} className="text-sm" />
						{t("contact.aside_email_heading")}
					</h2>
					<a
						class="font-headline border-b border-outline-variant/30 pb-2 text-2xl font-medium text-on-surface transition-colors hover:text-primary-container md:text-3xl"
						href={`mailto:${t("contact.email_address")}`}
					>
						{t("contact.email_address")}
					</a>
				</div>

				<div>
					<h2
						class="font-label mb-6 flex items-center gap-2 text-xs uppercase tracking-aside text-tertiary-light"
					>
						<MarketingIcon name="location_on" size={16} className="text-sm" />
						{t("contact.aside_locations_heading")}
					</h2>
					<div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
						<div class="group">
							<p class="font-headline text-xl text-on-surface">{t("contact.location_split")}</p>
							<p class="mt-1 text-sm text-on-surface-variant">{t("contact.location_split_sub")}</p>
							<p class="mt-2 text-sm leading-relaxed text-on-surface-variant">
								{t("contact.location_split_address")}
							</p>
							<div
								class="mt-4 h-px w-0 bg-secondary-focus transition-all duration-500 group-hover:w-full"
								aria-hidden="true"
							>
							</div>
						</div>
						<div class="group">
							<p class="font-headline text-xl text-on-surface">{t("contact.location_trondheim")}</p>
							<p class="mt-1 text-sm text-on-surface-variant">
								{t("contact.location_trondheim_sub")}
							</p>
							<p class="mt-2 text-sm leading-relaxed text-on-surface-variant">
								{t("contact.location_trondheim_address")}
							</p>
							<div
								class="mt-4 h-px w-0 bg-secondary-focus transition-all duration-500 group-hover:w-full"
								aria-hidden="true"
							>
							</div>
						</div>
					</div>
				</div>

				<div>
					<h2
						class="font-label mb-6 flex items-center gap-2 text-xs uppercase tracking-aside text-tertiary-light"
					>
						<MarketingIcon name="share" size={16} className="text-sm" />
						{t("contact.aside_social_heading")}
					</h2>
					<div class="flex flex-wrap gap-4">
						<a
							class="font-label rounded-full border border-outline-variant/10 bg-surface-container px-6 py-2 text-sm uppercase tracking-widest text-on-surface-variant transition-all hover:bg-surface-container-high hover:text-secondary"
							href="https://www.linkedin.com"
							target="_blank"
							rel="noopener noreferrer"
						>
							{t("contact.social_linkedin")}
						</a>
						<a
							class="font-label rounded-full border border-outline-variant/10 bg-surface-container px-6 py-2 text-sm uppercase tracking-widest text-on-surface-variant transition-all hover:bg-surface-container-high hover:text-secondary"
							href="https://github.com"
							target="_blank"
							rel="noopener noreferrer"
						>
							{t("contact.social_github")}
						</a>
						<a
							class="font-label rounded-full border border-outline-variant/10 bg-surface-container px-6 py-2 text-sm uppercase tracking-widest text-on-surface-variant transition-all hover:bg-surface-container-high hover:text-secondary"
							href="https://www.instagram.com"
							target="_blank"
							rel="noopener noreferrer"
						>
							{t("contact.social_instagram")}
						</a>
					</div>
				</div>
			</div>

			<div class="mt-12 opacity-40">
				<div
					class="aspect-video w-full overflow-hidden rounded-xl border border-border bg-surface-container grayscale"
				>
					<Image
						src={splitVidilice}
						alt={t("contact.location_image_alt")}
						width={splitVidilice.width}
						height={splitVidilice.height}
						sizes="(max-width: 1024px) 100vw, min(42rem, 40vw)"
						loading="lazy"
						decoding="async"
						format="avif"
						class="size-full object-cover object-center"
					/>
				</div>
			</div>
		</aside>
	</div>
</main>

<script
	define:vars={{
		loadingLabel: contactFormLoading,
		successLabel: contactFormSuccess,
		errorLabel: contactFormError,
		rateLimitedLabel: contactFormRateLimited,
		submitLabel: contactFormSubmit,
	}}
>
	const w = globalThis;
	const CONTACT_FORM_HASH = "#contact-form";
	const CONTACT_FORM_TRACKING_PARAMS = [
		"_gl",
		"_ga",
		"_up",
		"_gid",
		"_gac",
		"_gcl_aw",
		"_gcl_dc",
		"_gcl_au",
	];

	function cleanContactFormUrl() {
		if (window.location.hash !== CONTACT_FORM_HASH || !window.location.search) return;

		const url = new URL(window.location.href);
		for (const param of [...url.searchParams.keys()]) {
			if (
				CONTACT_FORM_TRACKING_PARAMS.includes(param) ||
				param.startsWith("_ga_") ||
				param.startsWith("_gac_")
			) {
				url.searchParams.delete(param);
			}
		}

		const query = url.searchParams.toString();
		const cleanUrl = `${url.pathname}${query ? `?${query}` : ""}${CONTACT_FORM_HASH}`;
		window.history.replaceState(window.history.state, "", cleanUrl);
	}

	function focusContactFormFromHash() {
		if (window.location.hash !== CONTACT_FORM_HASH) return;
		cleanContactFormUrl();
		const formTarget = document.querySelector(CONTACT_FORM_HASH);
		const firstField = document.querySelector("#contact-name");
		requestAnimationFrame(() => {
			if (formTarget instanceof HTMLElement) {
				formTarget.scrollIntoView({ block: "start" });
			}
			if (firstField instanceof HTMLElement) {
				firstField.focus({ preventScroll: true });
			} else if (formTarget instanceof HTMLElement) {
				formTarget.focus({ preventScroll: true });
			}
		});
	}

	focusContactFormFromHash();
	if (!w.__digiContactFormFocusBound) {
		w.__digiContactFormFocusBound = true;
		window.addEventListener("hashchange", focusContactFormFromHash);
		document.addEventListener("astro:page-load", focusContactFormFromHash);
	}

	if (!w.__digiContactFormBound) {
		w.__digiContactFormBound = true;
		document.addEventListener("submit", async (e) => {
			const target = e.target;
			if (!(target instanceof Element)) return;
			const form = target.closest("[data-contact-form]");
			if (!(form instanceof HTMLFormElement)) return;
			e.preventDefault();

			const feedback = form.querySelector("[data-contact-feedback]");
			const submitBtn = form.querySelector("[data-contact-submit]");
			if (!(feedback instanceof HTMLParagraphElement) || !(submitBtn instanceof HTMLButtonElement)) return;

			feedback.textContent = "";
			feedback.classList.add("hidden");
			feedback.classList.remove("text-emerald-400", "text-red-400");

			const fd = new FormData(form);
			const name = String(fd.get("name") ?? "").trim();
			const company = String(fd.get("company") ?? "").trim();
			const email = String(fd.get("email") ?? "").trim();
			const message = String(fd.get("message") ?? "").trim();
			const contact_hp = String(fd.get("contact_hp") ?? "").trim();

			submitBtn.disabled = true;
			submitBtn.textContent = loadingLabel;

			try {
				const res = await fetch("/api/contact", {
					method: "POST",
					headers: { "Content-Type": "application/json", Accept: "application/json" },
					body: JSON.stringify({ name, email, company, message, contact_hp }),
				});

				if (res.ok) {
					feedback.textContent = successLabel;
					feedback.classList.remove("hidden");
					feedback.classList.add("text-emerald-400");
					form.reset();
				} else if (res.status === 429) {
					feedback.textContent = rateLimitedLabel;
					feedback.classList.remove("hidden");
					feedback.classList.add("text-red-400");
				} else {
					feedback.textContent = errorLabel;
					feedback.classList.remove("hidden");
					feedback.classList.add("text-red-400");
				}
			} catch {
				feedback.textContent = errorLabel;
				feedback.classList.remove("hidden");
				feedback.classList.add("text-red-400");
			} finally {
				submitBtn.disabled = false;
				submitBtn.textContent = submitLabel;
			}
		});
	}
</script>
