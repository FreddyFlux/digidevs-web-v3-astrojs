---
import MobileNav from "./MobileNav";

interface Props {
	pathname: string;
}

const { pathname } = Astro.props;

const nav = [
	{ href: "/", label: "Home" },
	{ href: "/blog", label: "Blog" },
	{ href: "/about", label: "About" },
] as const;

function active(href: string) {
	if (href === "/") return pathname === "/";
	return pathname === href || pathname.startsWith(`${href}/`);
}
---

<header
	class="fixed top-0 left-0 z-50 flex w-full items-center justify-between bg-transparent px-8 py-6 backdrop-blur-xl"
>
	<a
		href="/"
		class="font-headline text-xl font-bold tracking-tighter text-white"
		aria-current={pathname === "/" ? "page" : undefined}
	>
		digiDEVS
	</a>

	<nav class="hidden items-center gap-8 md:flex" aria-label="Primary">
		{
			nav.map(({ href, label }) => {
				const isCurrent = active(href);
				return (
					<a
						href={href}
						class:list={[
							"font-label text-sm uppercase tracking-widest transition-colors",
							isCurrent
								? "border-b border-white/40 pb-1 font-bold text-white"
								: "text-white/60 hover:text-white",
						]}
						aria-current={isCurrent ? "page" : undefined}
					>
						{label}
					</a>
				);
			})
		}
	</nav>

	<div class="flex items-center gap-4">
		<MobileNav client:idle pathname={pathname} />
	</div>
</header>
