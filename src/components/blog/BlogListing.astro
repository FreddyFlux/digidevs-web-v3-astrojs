---
import { Image } from "astro:assets";
import type { Locale } from "../../i18n/locales";
import MarketingIcon from "../icons/MarketingIcon";
import type { BlogPost } from "../../lib/blog";
import { buildBlogListingHref, formatCategories, toggleCategoryInSelection } from "../../lib/blog";
import { useTranslations } from "../../i18n/utils";

interface Props {
	lang: Locale;
	/** `""` for default locale (`/blog`), or `"/en"` / `"/hr"` */
	urlPrefix: string;
	featured: BlogPost | undefined;
	posts: BlogPost[];
	categoryOptions: string[];
	selectedCategories: string[];
	showSanityEmpty: boolean;
	showFilterEmpty: boolean;
}

const {
	lang,
	urlPrefix,
	featured,
	posts,
	categoryOptions,
	selectedCategories,
	showSanityEmpty,
	showFilterEmpty,
} = Astro.props;

const t = useTranslations(lang);

const dateLocales: Record<Locale, string> = { no: "nb-NO", en: "en-GB", hr: "hr-HR" };
const dateLocale = dateLocales[lang];
---

<main class="pb-28 pt-36">
	<header class="mx-auto mb-24 max-w-7xl px-6 md:px-10" transition:animate="fade">
		<div class="mb-6">
			<span class="font-label text-sm uppercase tracking-[0.3em] text-on-surface-variant">{t("blog.journal_label")}</span>
		</div>
		<h1
			class="font-headline max-w-4xl text-6xl font-bold leading-[0.95] tracking-editorial text-on-surface md:text-8xl"
			transition:animate="slide"
		>
			{t("blog.heading_line1")} <br /><span class="font-body italic text-on-surface-variant">{t("blog.heading_line2")}</span>
		</h1>
	</header>

	{
		categoryOptions.length > 0 && (
			<nav
				class="mx-auto mb-16 max-w-7xl px-6 md:px-10"
				aria-label={t("blog.filter_aria")}
			>
				<div class="flex flex-wrap items-center gap-3">
					<span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">{t("blog.filter_label")}</span>
					{categoryOptions.map((cat) => {
						const isActive = selectedCategories.includes(cat);
						const next = toggleCategoryInSelection(selectedCategories, cat);
						const href = buildBlogListingHref(urlPrefix, next);
						return (
							<a
								href={href}
								class:list={[
									"font-label rounded-full border px-4 py-2 text-[11px] uppercase tracking-widest transition-colors",
									isActive
										? "border-secondary bg-secondary/25 text-secondary"
										: "border-outline/30 bg-surface-container-low text-on-surface-variant hover:border-secondary/50 hover:text-on-surface",
								]}
								aria-pressed={isActive}
							>
								{cat}
							</a>
						);
					})}
					{selectedCategories.length > 0 && (
						<a
							href={buildBlogListingHref(urlPrefix, [])}
							class="font-label ml-1 text-[11px] uppercase tracking-widest text-primary underline-offset-4 hover:underline"
						>
							{t("blog.filter_clear")}
						</a>
					)}
				</div>
			</nav>
		)
	}

	{
		featured && !showFilterEmpty && (
			<section class="mx-auto mb-32 max-w-7xl px-6 md:px-10">
				<div class="blog-listing-featured-row grid grid-cols-1 items-center gap-12 lg:grid-cols-12">
					<div class="group cursor-pointer overflow-hidden rounded-2xl bg-surface-container-low lg:col-span-7">
						<a href={`${urlPrefix}/blog/${featured.slug}`} class="block">
							<Image
								src={featured.coverImageUrl}
								alt={featured.coverImageAlt}
								width={1200}
								height={900}
								sizes="(min-width: 1024px) 60vw, 100vw"
								class="blog-listing-image h-[500px] w-full object-cover opacity-85 transition-[transform,filter] duration-700 group-hover:scale-[1.03]"
								loading="eager"
								decoding="async"
								format="avif"
								transition:name={`blog-cover-${featured.slug}`}
							/>
						</a>
					</div>
					<div class="z-10 lg:-ml-12 lg:col-span-5">
						<div class="group glass-panel ambient-glow rounded-2xl p-10">
							<span class="font-label mb-6 block text-xs uppercase tracking-widest text-primary">
								{formatCategories(featured.categories)} • {featured.readTime}
							</span>
							<h2 class="font-headline mb-6 text-4xl font-bold leading-tight tracking-editorial text-on-surface">
								{featured.title}
							</h2>
							<p class="font-body mb-8 leading-relaxed text-on-surface-variant">{featured.description}</p>
							<a
								class="link-tertiary inline-flex items-center gap-3 font-label text-sm font-medium uppercase tracking-widest"
								href={`${urlPrefix}/blog/${featured.slug}`}
							>
								{t("blog.read_full")}
								<MarketingIcon
									name="east"
									className="transition-transform group-hover:translate-x-2"
									size={20}
								/>
							</a>
						</div>
					</div>
				</div>
			</section>
		)
	}

	{
		showSanityEmpty && (
			<section class="mx-auto mb-32 max-w-7xl px-6 md:px-10">
				<p class="font-body max-w-xl text-on-surface-variant">
					{t("blog.empty_pre")}
					<code class="rounded bg-surface-container-high px-1.5 py-0.5 text-sm">{t("blog.empty_code")}</code>
					{t("blog.empty_post")}
				</p>
			</section>
		)
	}

	{
		showFilterEmpty && (
			<section class="mx-auto mb-32 max-w-7xl px-6 md:px-10">
				<p class="font-body max-w-xl text-on-surface-variant">{t("blog.filter_empty")}</p>
			</section>
		)
	}

	<section class="mx-auto max-w-7xl px-6 md:px-10">
		<div class="grid grid-cols-1 gap-x-12 gap-y-20 md:grid-cols-3">
			{
				!showSanityEmpty &&
					!showFilterEmpty &&
					posts.map((post) => (
						<article class="blog-listing-card flex flex-col">
							<a
								href={`${urlPrefix}/blog/${post.slug}`}
								class="mb-8 aspect-square overflow-hidden rounded-2xl bg-surface-container-low"
							>
								<Image
									src={post.coverImageUrl}
									alt={post.coverImageAlt}
									width={600}
									height={600}
									sizes="(min-width: 768px) 33vw, 100vw"
									class="blog-listing-image h-full w-full object-cover opacity-80 transition-all duration-500 hover:opacity-100"
									loading="lazy"
									decoding="async"
									format="avif"
									transition:name={`blog-cover-${post.slug}`}
								/>
							</a>
							<div class="mb-4 flex flex-wrap items-center gap-3">
								<div class="flex flex-wrap gap-2">
									{(post.categories ?? []).map((c) => (
										<span class="font-label rounded-full bg-secondary/20 px-3 py-1 text-[10px] uppercase tracking-widest text-secondary">
											{c}
										</span>
									))}
								</div>
								<span class="font-label text-[10px] text-on-surface-variant/70">
									{new Date(post.date).toLocaleDateString(dateLocale, {
										year: "numeric",
										month: "long",
										day: "numeric",
									})}
								</span>
							</div>
							<h3 class="font-headline mb-4 cursor-pointer text-2xl font-bold tracking-editorial text-on-surface transition-colors hover:text-primary">
								<a href={`${urlPrefix}/blog/${post.slug}`}>{post.title}</a>
							</h3>
							<p class="font-body mb-6 text-sm leading-relaxed text-on-surface-variant">{post.description}</p>
							<div class="mt-auto flex items-center gap-3 pt-6">
								<div class="flex h-7 w-7 items-center justify-center rounded-full bg-surface-container-highest">
									<MarketingIcon name="person" className="text-[14px] text-on-surface-variant" size={14} />
								</div>
								<span class="font-label text-xs text-on-surface-variant">{post.author}</span>
							</div>
						</article>
					))
			}
		</div>

		<div class="mt-28 flex flex-col items-center">
			<div class="mb-8 h-24 w-px bg-gradient-to-b from-primary/50 to-transparent"></div>
			<button
				type="button"
				class="font-label text-xs uppercase tracking-[0.4em] text-on-surface-variant transition-colors hover:text-secondary"
			>
				{t("blog.load_more")}
			</button>
		</div>
	</section>

	<section class="relative mx-auto mt-40 max-w-4xl overflow-hidden rounded-2xl bg-surface-container-low px-6 py-20 md:px-10">
		<div class="pointer-events-none absolute right-0 top-0 h-64 w-64 rounded-full bg-primary/10 blur-[120px]"></div>
		<div class="relative z-10 text-center">
			<h2 class="font-headline mb-4 text-4xl font-bold tracking-editorial text-on-surface">{t("blog.digest_title")}</h2>
			<p class="mx-auto mb-10 max-w-lg font-body text-on-surface-variant">
				{t("blog.digest_body")}
			</p>
			<form class="mx-auto flex max-w-md flex-col gap-4 md:flex-row md:items-stretch" action="#" method="post">
				<input
					class="input-editorial font-body flex-1"
					placeholder={t("blog.email_placeholder")}
					type="email"
					name="email"
					autocomplete="email"
				/>
				<button
					type="button"
					class="btn-primary-gradient shrink-0 rounded-xl px-8 py-3 font-label text-sm font-semibold uppercase tracking-widest transition-all hover:brightness-105 active:scale-[0.98]"
				>
					{t("blog.subscribe")}
				</button>
			</form>
		</div>
	</section>
</main>
