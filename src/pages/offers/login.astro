---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import { isOfferAccessAllowed } from "../../lib/offer-access";
import { getOfferGateSecret } from "../../lib/offer-gate-env";

const gateConfigured = Boolean(getOfferGateSecret());
const redirectRaw = Astro.url.searchParams.get("redirect") ?? "/offers";
const redirect =
	redirectRaw.startsWith("/") && !redirectRaw.startsWith("//") ? redirectRaw : "/offers";
const showError = Astro.url.searchParams.get("error") === "1";

if (gateConfigured && isOfferAccessAllowed(Astro.request)) {
	return Astro.redirect(redirect);
}
---

<Layout
	title="Offers — sign in — digiDEVS"
	description="Password-protected offers"
	lang="no"
	noIndex={true}
	logoOnlyHeaderHref="/"
>
	<div class="mx-auto flex min-h-[70vh] max-w-md flex-col justify-center px-6 pb-24 pt-28 md:px-10">
		<h1 class="font-headline mb-2 text-2xl font-bold tracking-editorial text-on-surface">Offers</h1>
		<p class="font-body mb-8 text-sm text-on-surface-variant">Enter the password to view commercial offers.</p>

		{
			!gateConfigured && (
				<div class="mb-6 rounded-xl border border-tertiary/30 bg-tertiary/10 px-4 py-3 text-sm text-on-surface">
					Offer password is not configured. Set <code class="text-primary">OFFER_ACCESS_PASSWORD</code> in{" "}
					<code class="text-primary">.env</code> (see <code class="text-primary">.env.example</code>).
				</div>
			)
		}

		{
			showError && gateConfigured && (
				<p class="mb-4 text-sm text-error" role="alert">
					Incorrect password. Try again.
				</p>
			)
		}

		{
			gateConfigured && (
				<form method="post" action="/api/offers/login" class="space-y-4">
					<input type="hidden" name="redirect" value={redirect} />
					<div>
						<label for="offer-password" class="font-label mb-2 block text-xs font-semibold uppercase tracking-wider text-on-surface-variant">
							Password
						</label>
						<input
							id="offer-password"
							name="password"
							type="password"
							required
							autocomplete="current-password"
							class="input-editorial w-full"
						/>
					</div>
					<button
						type="submit"
						class="btn-primary-gradient font-label w-full rounded-xl px-4 py-3 text-sm font-medium"
					>
						Sign in
					</button>
				</form>
			)
		}
	</div>
</Layout>
