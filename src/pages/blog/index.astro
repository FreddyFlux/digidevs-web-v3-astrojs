---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import BlogListing from "../../components/blog/BlogListing.astro";
import {
	collectCategoriesFromPosts,
	fetchAllPosts,
	filterPostsByCategories,
	getFeaturedPost,
	getGridPosts,
	parseCategoryFiltersFromSearchParams,
} from "../../lib/blog";
import { useTranslations } from "../../i18n/utils";
import { buildBlogIndexBreadcrumbItems, buildBlogIndexJsonLd } from "../../lib/seo-jsonld";

const t = useTranslations("no");
const siteBase = (import.meta.env.PUBLIC_SITE_URL ?? "https://digidevs.no").replace(/\/$/, "");
const blogIndexJsonLd = buildBlogIndexJsonLd(siteBase, "no", {
	title: t("blog.meta_title"),
	description: t("blog.meta_description"),
	breadcrumbItems: buildBlogIndexBreadcrumbItems(siteBase, "no", t),
});
const allPosts = await fetchAllPosts("no");
const selectedCategories = parseCategoryFiltersFromSearchParams(Astro.url.searchParams);
const filteredPosts = filterPostsByCategories(allPosts, selectedCategories);
const featured = getFeaturedPost(filteredPosts);
const posts = getGridPosts(filteredPosts, featured);
const categoryOptions = collectCategoriesFromPosts(allPosts);

const showSanityEmpty = allPosts.length === 0;
const showFilterEmpty =
	allPosts.length > 0 && selectedCategories.length > 0 && filteredPosts.length === 0;
---

<Layout title={t("blog.meta_title")} description={t("blog.meta_description")} lang="no">
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(blogIndexJsonLd)} />
	<BlogListing
		lang="no"
		urlPrefix=""
		featured={featured}
		posts={posts}
		categoryOptions={categoryOptions}
		selectedCategories={selectedCategories}
		showSanityEmpty={showSanityEmpty}
		showFilterEmpty={showFilterEmpty}
	/>
</Layout>
