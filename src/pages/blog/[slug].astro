---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import { fetchPostBySlug, formatCategories } from "../../lib/blog";

/** Resolve at request time so new Sanity posts work in dev (getStaticPaths is cached; /blog listing is not). */
export const prerender = false;

const slug = Astro.params.slug;
if (!slug) {
	return new Response(null, { status: 404, statusText: "Not Found" });
}

const post = await fetchPostBySlug("no", slug);
if (!post) {
	return new Response(null, { status: 404, statusText: "Not Found" });
}

const siteBase = (import.meta.env.PUBLIC_SITE_URL ?? "https://digidevs.no").replace(/\/$/, "");
const pageTitle = post.seoTitle ? `${post.seoTitle} — digiDEVS` : `${post.title} — digiDEVS`;
const pageDesc = post.seoDescription ?? post.description;
const canonical = post.canonicalUrl ?? `${siteBase}/blog/${post.slug}`;

const keywordsMeta = post.seoKeywords?.length ? post.seoKeywords.join(", ") : undefined;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: post.title,
	description: pageDesc,
	...(post.seoKeywords?.length && { keywords: post.seoKeywords.join(", ") }),
	image: [post.coverImageUrl],
	datePublished: post.date,
	dateModified: post.updatedAt ?? post.date,
	author: {
		"@type": "Person",
		name: post.author,
	},
	publisher: {
		"@type": "Organization",
		name: "digiDEVS",
		url: siteBase,
	},
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": canonical,
	},
};

const dateLocale = "nb-NO";
---

<Layout
	title={pageTitle}
	description={pageDesc}
	keywords={keywordsMeta}
	lang="no"
	canonicalUrl={canonical}
	ogImage={post.coverImageUrl}
	ogType="article"
	noIndex={post.noIndex ?? false}
>
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
	<article class="mx-auto max-w-3xl px-6 pb-28 pt-36 md:px-10">
		<header class="mb-12">
			<p class="font-label mb-4 text-xs uppercase tracking-widest text-primary">
				{formatCategories(post.categories)} • {post.readTime}
			</p>
			<h1 class="font-headline mb-6 text-4xl font-bold leading-tight tracking-editorial text-on-surface md:text-5xl">
				{post.title}
			</h1>
			<p class="font-body text-lg text-on-surface-variant">{post.description}</p>
			<p class="font-label mt-6 text-sm text-on-surface-variant/80">
				{new Date(post.date).toLocaleDateString(dateLocale, { year: "numeric", month: "long", day: "numeric" })} · {
					post.author
				}
			</p>
		</header>

		<div class="mb-12 overflow-hidden rounded-2xl bg-surface-container-low">
			<Image
				src={post.coverImageUrl}
				alt={post.coverImageAlt}
				width={1200}
				height={675}
				sizes="(min-width: 768px) 768px, 100vw"
				class="aspect-video w-full object-cover"
				loading="eager"
				decoding="async"
				format="avif"
				transition:name={`blog-cover-${slug}`}
			/>
		</div>

		<div
			class="font-body space-y-6 text-lg leading-relaxed text-on-surface-variant [&_blockquote]:border-l-4 [&_blockquote]:border-primary/40 [&_blockquote]:pl-4 [&_blockquote]:italic [&_h2]:mt-12 [&_h2]:font-headline [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:tracking-editorial [&_h2]:text-on-surface [&_h3]:mt-8 [&_h3]:font-headline [&_h3]:text-xl [&_h3]:font-bold [&_h3]:text-on-surface [&_p]:mb-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:list-decimal [&_ol]:pl-6"
			set:html={post.bodyHtml}
		/>
	</article>
</Layout>
