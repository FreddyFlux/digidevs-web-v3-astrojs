---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Contact — digiDEVS"
	description="Get in touch with digiDEVS — Norwegian-led development, web and mobile apps, and AI-powered products."
>
	<main class="relative mx-auto max-w-4xl px-6 pb-28 pt-36 md:px-10">
		<header class="mb-16">
			<span class="font-label mb-4 block text-xs uppercase tracking-[0.3em] text-secondary">Get in touch</span>
			<h1 class="font-headline text-5xl font-bold tracking-editorial text-on-surface md:text-7xl">Contact</h1>
			<p class="font-body mt-8 max-w-2xl text-lg leading-relaxed text-on-surface-variant">
				Tell us about your project or technical horizon. We will respond as soon as we can.
			</p>
		</header>
		<section>
			<p class="font-body rounded-2xl border border-on-surface-variant/20 bg-surface-container-low/50 p-8 text-on-surface-variant">
				Contact form and details will be added here.
			</p>
		</section>
	</main>
</Layout>
