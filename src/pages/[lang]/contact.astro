---
import type { Locale } from "../../i18n/locales";
import { DEFAULT_LOCALE, LOCALES } from "../../i18n/locales";
import Layout from "../../layouts/Layout.astro";
import { useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
	return LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((lang) => ({ params: { lang } }));
}

const { lang: langParam } = Astro.params;
const lang = langParam as Locale;
const t = useTranslations(lang);
---

<Layout title={t("contact.meta_title")} description={t("contact.meta_description")} lang={lang}>
	<main class="relative mx-auto max-w-4xl px-6 pb-28 pt-36 md:px-10">
		<header class="mb-16">
			<span class="font-label mb-4 block text-xs uppercase tracking-[0.3em] text-secondary">{t("contact.label")}</span>
			<h1 class="font-headline text-5xl font-bold tracking-editorial text-on-surface md:text-7xl">{t("contact.heading")}</h1>
			<p class="font-body mt-8 max-w-2xl text-lg leading-relaxed text-on-surface-variant">
				{t("contact.intro")}
			</p>
		</header>
		<section>
			<p class="font-body rounded-2xl border border-on-surface-variant/20 bg-surface-container-low/50 p-8 text-on-surface-variant">
				{t("contact.placeholder")}
			</p>
		</section>
	</main>
</Layout>
