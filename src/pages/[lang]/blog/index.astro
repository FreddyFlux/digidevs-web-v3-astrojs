---
export const prerender = false;

import type { Locale } from "../../../i18n/locales";
import { DEFAULT_LOCALE, LOCALES } from "../../../i18n/locales";
import Layout from "../../../layouts/Layout.astro";
import BlogListing from "../../../components/blog/BlogListing.astro";
import {
	collectCategoriesFromPosts,
	fetchAllPosts,
	filterPostsByCategories,
	getFeaturedPost,
	getGridPosts,
	parseCategoryFiltersFromSearchParams,
} from "../../../lib/blog";
import { useTranslations } from "../../../i18n/utils";

const LOCALES_PREFIXED = LOCALES.filter((l) => l !== DEFAULT_LOCALE);
const { lang: langParam } = Astro.params;
if (!langParam || !LOCALES_PREFIXED.includes(langParam as Locale)) {
	return new Response(null, { status: 404, statusText: "Not Found" });
}

const lang = langParam as Locale;
const t = useTranslations(lang);
const allPosts = await fetchAllPosts(lang);
const selectedCategories = parseCategoryFiltersFromSearchParams(Astro.url.searchParams);
const filteredPosts = filterPostsByCategories(allPosts, selectedCategories);
const featured = getFeaturedPost(filteredPosts);
const posts = getGridPosts(filteredPosts, featured);
const categoryOptions = collectCategoriesFromPosts(allPosts);
const urlPrefix = `/${lang}`;

const showSanityEmpty = allPosts.length === 0;
const showFilterEmpty =
	allPosts.length > 0 && selectedCategories.length > 0 && filteredPosts.length === 0;
---

<Layout title={t("blog.meta_title")} description={t("blog.meta_description")} lang={lang}>
	<BlogListing
		lang={lang}
		urlPrefix={urlPrefix}
		featured={featured}
		posts={posts}
		categoryOptions={categoryOptions}
		selectedCategories={selectedCategories}
		showSanityEmpty={showSanityEmpty}
		showFilterEmpty={showFilterEmpty}
	/>
</Layout>
