---
import { Image } from "astro:assets";
import type { Locale } from "../../i18n/locales";
import { DEFAULT_LOCALE, LOCALES } from "../../i18n/locales";
import Layout from "../../layouts/Layout.astro";
import MarketingIcon from "../../components/icons/MarketingIcon";
import StaticGlassBox from "../../components/ui/StaticGlassBox.astro";
import { useTranslations } from "../../i18n/utils";
import { buildHomepageJsonLd } from "../../lib/seo-jsonld";
import heroNorsk from "../../assets/digidevs-norsk-hero.png";
import bentoOpera from "../../assets/digidevs-opera.jpg";
import bentoKeyboard from "../../assets/digidevs-keyboard.png";

export function getStaticPaths() {
	return LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((lang) => ({ params: { lang } }));
}

const { lang: langParam } = Astro.params;
const lang = langParam as Locale;
const t = useTranslations(lang);
const siteBase = (import.meta.env.PUBLIC_SITE_URL ?? "https://digidevs.no").replace(/\/$/, "");
const homepageJsonLd = buildHomepageJsonLd(siteBase, lang, { description: t("home.meta_description") });
---

<Layout title={t("home.meta_title")} description={t("home.meta_description")} lang={lang}>
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(homepageJsonLd)} />
	<main class="bg-background">
		<section class="relative isolate flex min-h-svh w-full flex-col justify-center overflow-hidden">
			<div class="absolute inset-0 z-0 min-h-svh w-full">
				<Image
					src={heroNorsk}
					alt={t("home.hero_img_alt")}
					width={heroNorsk.width}
					height={heroNorsk.height}
					layout="full-width"
					fit="cover"
					position="center"
					sizes="100vw"
					quality="high"
					format="avif"
					priority
					decoding="async"
					class="absolute inset-0 z-0 size-full object-cover object-center"
				/>
				<div
					class="pointer-events-none absolute inset-0 z-10 bg-linear-to-b from-background/20 via-background/60 to-background"
					aria-hidden="true"
				>
				</div>
			</div>
			<div
				class="pointer-events-none absolute right-0 top-1/4 z-15 h-96 w-96 rounded-full bg-secondary aurora-blur"
				aria-hidden="true"
			>
			</div>
			<div
				class="pointer-events-none absolute bottom-1/4 left-1/4 z-15 h-[500px] w-[500px] rounded-full bg-primary aurora-blur"
				aria-hidden="true"
			>
			</div>

			<div class="relative z-20 mx-auto w-full max-w-[1200px] px-6 pb-16 pt-28 md:px-10 md:pb-24 md:pt-32 lg:px-12">
				<h1
					class="font-headline text-[clamp(3rem,calc(6vw+1rem),4.86rem)] font-black leading-[1.01] tracking-tighter text-on-surface"
					transition:animate="slide"
				>
					{t("home.hero_headline_1")}
					<br />
					<span class="text-primary-container">{t("home.hero_headline_2")}</span>
					<br />
					<span class="text-[70%] font-light italic text-on-surface">
						{t("home.hero_headline_3")}
					</span>
				</h1>

				<div class="mt-40 max-w-lg md:mt-40 md:max-w-none">
					<div class="grid grid-cols-12 gap-6">

						<div class="order-1 col-span-12 md:order-2 md:col-span-5 md:col-start-7">
							<StaticGlassBox class="mb-6 px-4 py-3 sm:mb-10 sm:px-8 sm:py-5">
								<p class="font-body text-sm font-light leading-relaxed text-[#111111] sm:text-base md:text-xl">
									{t("home.hero_body")}
								</p>
							</StaticGlassBox>
							<div class="mb-8 flex flex-wrap items-center gap-4 md:mb-12 md:gap-8">
								<a
									class="inline-flex rounded-full bg-primary-container px-6 py-3 font-headline text-sm font-bold uppercase tracking-tighter text-on-primary-container transition-transform hover:scale-95 md:px-10 md:py-5 md:text-lg"
									href={`/${lang}/contact`}
								>
									{t("home.cta_call")}
								</a>
								<a
									class="font-label border-b-2 border-primary-container/30 pb-1 text-sm uppercase tracking-tighter text-primary-container transition-all hover:border-primary-container"
									href={`/${lang}/blog?category=Work`}
								>
									{t("home.cta_work")}
								</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section
			id="capabilities"
			class="bg-surface px-6 py-24 md:px-10 md:py-32 lg:px-12"
			transition:animate="fade"
		>
			<div class="mx-auto max-w-[1920px]">
				<div class="mb-16 md:mb-20">
					<h2 class="font-headline text-4xl font-bold uppercase tracking-tighter md:text-5xl">
						{t("home.capabilities_heading")}
					</h2>
					<div class="mt-2 h-1 w-20 bg-secondary"></div>
				</div>

				<div class="grid auto-rows-auto grid-cols-1 gap-6 md:grid-cols-12 md:auto-rows-[350px]">
					<div
						class="group relative flex min-h-[min(620px,98vw)] flex-col justify-start overflow-hidden bg-surface-container-low p-8 max-md:pb-5 md:min-h-0 md:justify-end md:col-span-8 md:row-span-2 md:p-10"
					>
						<Image
							src={bentoOpera}
							alt={t("home.bento_opera_alt")}
							width={bentoOpera.width}
							height={bentoOpera.height}
							class="absolute inset-0 h-full w-full object-cover opacity-55 transition-transform duration-700 group-hover:scale-105"
							loading="lazy"
							decoding="async"
						/>
						<div
							class="pointer-events-none absolute inset-0 z-1 bg-[linear-gradient(to_top,var(--color-background)_0%,var(--color-background)_18%,color-mix(in_oklab,var(--color-background)_25%,transparent)_35%,transparent_76%)] md:bg-[linear-gradient(to_top,var(--color-background)_0%,var(--color-background)_8%,color-mix(in_oklab,var(--color-background)_15%,transparent)_22%,transparent_76%)]"
							aria-hidden="true"
						>
						</div>
						<div
							class="relative z-10 flex w-full flex-col max-md:min-h-0 max-md:flex-1 md:block"
						>
							<span class="mb-4 block font-headline text-sm uppercase tracking-widest text-secondary"
								>{t("home.bento_guide_label")}</span
							>
							<h3 class="mb-8 font-headline text-3xl font-bold tracking-tighter text-on-surface md:mb-10 md:text-4xl">
								{t("home.bento_guide_title")}
							</h3>
							<p class="text-bento-body max-w-md max-md:mt-auto max-md:translate-y-1.5">
								{t("home.bento_guide_body")}
							</p>
						</div>
					</div>

					<div
						class="flex flex-col gap-3 border-l-2 border-secondary/40 bg-surface-container p-5 md:col-span-4 md:justify-between md:gap-0 md:p-8"
					>
						<MarketingIcon name="science" size={36} className="shrink-0 text-secondary" />
						<div>
							<h3 class="mb-1.5 font-headline text-xl font-bold tracking-tighter md:mb-2 md:text-2xl">{t("home.bento_ai_title")}</h3>
							<p class="text-bento-body text-sm leading-snug">{t("home.bento_ai_body")}</p>
						</div>
					</div>

					<div class="flex flex-col gap-3 bg-surface-container-high p-5 md:col-span-4 md:justify-between md:gap-0 md:p-8">
						<div class="h-1 w-10 shrink-0 bg-tertiary md:mb-0 md:w-12"></div>
						<div>
							<h3 class="mb-1.5 font-headline text-xl font-bold tracking-tighter md:mb-2 md:text-2xl">{t("home.bento_web_title")}</h3>
							<p class="text-bento-body text-sm leading-snug">{t("home.bento_web_body")}</p>
						</div>
					</div>

					<div
						class="flex flex-col items-center justify-center bg-primary-container p-8 text-center md:col-span-4 md:p-10"
					>
						<h3 class="mb-6 font-headline text-2xl font-black tracking-tighter text-on-primary-container md:text-3xl">
							{t("home.bento_cta_title")}
						</h3>
						<a
							class="inline-flex rounded-full bg-surface px-8 py-3 font-headline text-sm font-bold uppercase tracking-tighter text-primary-container transition-colors hover:bg-surface-bright"
							href={`/${lang}/contact`}
						>
							{t("home.cta_call")}
						</a>
					</div>

					<div class="group relative overflow-hidden bg-surface-container-highest p-8 md:col-span-8 md:p-10">
						<div
							class="absolute inset-0 z-10 bg-linear-to-r from-background to-transparent"
							aria-hidden="true"
						>
						</div>
						<Image
							src={bentoKeyboard}
							alt=""
							width={1200}
							height={600}
							class="absolute inset-0 h-full w-full object-cover opacity-30"
							loading="lazy"
							decoding="async"
						/>
						<div class="relative z-20 flex h-full flex-col justify-center">
							<h3 class="mb-4 font-headline text-2xl font-bold tracking-tighter md:text-3xl">
								{t("home.bento_outsourced_title")}
							</h3>
							<p class="text-bento-body max-w-sm">
								{t("home.bento_outsourced_body")}
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="border-border border-t bg-surface-dim px-6 py-24 md:px-10 md:py-32 lg:px-12">
			<div class="mx-auto grid max-w-[1920px] grid-cols-12 gap-6 justify-items-center">
				<div class="col-span-12 text-center md:col-span-4">
					<h2 class="mb-4 font-headline text-5xl font-black tracking-tighter text-primary-container md:text-6xl">8</h2>
					<p class="font-headline text-xs uppercase tracking-widest text-on-surface-variant">{t("home.stats_pages")}</p>
				</div>
				<div class="col-span-12 text-center md:col-span-4 md:mt-24">
					<h2 class="mb-4 font-headline text-5xl font-black tracking-tighter text-secondary md:text-6xl">100%</h2>
					<p class="font-headline text-xs uppercase tracking-widest text-on-surface-variant">{t("home.stats_cutting")}</p>
				</div>
				<div class="col-span-12 text-center md:col-span-4 md:mt-12">
					<h2 class="mb-4 font-headline text-5xl font-black tracking-tighter text-tertiary md:text-6xl">0%</h2>
					<p class="font-headline text-xs uppercase tracking-widest text-on-surface-variant">{t("home.stats_bs")}</p>
				</div>
			</div>
		</section>
	</main>
</Layout>
