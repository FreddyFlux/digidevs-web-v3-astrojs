---
import { Image } from "astro:assets";
import type { Locale } from "../../i18n/locales";
import { DEFAULT_LOCALE, LOCALES } from "../../i18n/locales";
import Layout from "../../layouts/Layout.astro";
import StaticGlassBox from "../../components/ui/StaticGlassBox.astro";
import { useTranslations } from "../../i18n/utils";
import heroNorsk from "../../assets/digidevs-norsk-hero.png";
import bentoOpera from "../../assets/digidevs-opera.jpg";
import bentoKeyboard from "../../assets/digidevs-keyboard.png";

export function getStaticPaths() {
	return LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((lang) => ({ params: { lang } }));
}

const { lang: langParam } = Astro.params;
const lang = langParam as Locale;
const t = useTranslations(lang);
---

<Layout title={t("home.meta_title")} description={t("home.meta_description")} lang={lang}>
	<link
		slot="head"
		href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0&display=swap"
		rel="stylesheet"
	/>

	<main class="bg-background">
		<section class="relative isolate flex min-h-svh w-full flex-col justify-center overflow-hidden">
			<div class="absolute inset-0 z-0 min-h-svh w-full">
				<Image
					src={heroNorsk}
					alt={t("home.hero_img_alt")}
					width={heroNorsk.width}
					height={heroNorsk.height}
					layout="full-width"
					fit="cover"
					position="center"
					sizes="100vw"
					quality="high"
					format="avif"
					priority
					decoding="async"
					class="absolute inset-0 z-0 size-full object-cover object-center"
				/>
				<div
					class="pointer-events-none absolute inset-0 z-10 bg-linear-to-b from-background/20 via-background/60 to-background"
					aria-hidden="true"
				>
				</div>
			</div>
			<div
				class="pointer-events-none absolute right-0 top-1/4 z-15 h-96 w-96 rounded-full bg-secondary aurora-blur"
				aria-hidden="true"
			>
			</div>
			<div
				class="pointer-events-none absolute bottom-1/4 left-1/4 z-15 h-[500px] w-[500px] rounded-full bg-primary aurora-blur"
				aria-hidden="true"
			>
			</div>

			<div class="relative z-20 mx-auto w-full max-w-[1200px] px-6 pb-16 pt-28 md:px-10 md:pb-24 md:pt-32 lg:px-12">
				<h1
					class="font-headline text-[clamp(3rem,8vw,7.5rem)] font-black leading-[1.01] tracking-tighter text-on-surface"
				>
					{t("home.hero_headline_1")}
					<br />
					<span class="text-primary-container">{t("home.hero_headline_2")}</span>
					<br />
					<span class="text-[70%] font-light italic text-on-surface">
						{t("home.hero_headline_3")}
					</span>
				</h1>

				<div class="mt-10 max-w-lg md:max-w-none">
					<div class="grid grid-cols-12 gap-6">
						<div class="col-span-12 md:col-span-5 md:col-start-7">
							<StaticGlassBox class="mb-10">
								<p class="font-body text-lg font-light leading-relaxed text-[#111111] md:text-xl">
									{t("home.hero_body")}
								</p>
							</StaticGlassBox>
							<div class="mb-12 flex flex-wrap items-center gap-8">
								<button
									type="button"
									class="rounded-full bg-primary-container px-10 py-5 font-headline text-lg font-bold uppercase tracking-tighter text-on-primary-container transition-transform hover:scale-95"
								>
									{t("home.cta_call")}
								</button>
								<a
									class="font-label border-b-2 border-primary-container/30 pb-1 text-sm uppercase tracking-tighter text-primary-container transition-all hover:border-primary-container"
									href="#capabilities"
								>
									{t("home.cta_work")}
								</a>
							</div>
							<div class="max-w-xs">
								<div class="aurora-bar"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="capabilities" class="bg-surface px-6 py-24 md:px-10 md:py-32 lg:px-12">
			<div class="mx-auto max-w-[1920px]">
				<div class="mb-16 md:mb-20">
					<h2 class="font-headline text-4xl font-bold uppercase tracking-tighter md:text-5xl">
						{t("home.capabilities_heading")}
					</h2>
					<div class="mt-2 h-1 w-20 bg-secondary"></div>
				</div>

				<div class="grid auto-rows-[minmax(280px,auto)] grid-cols-1 gap-6 md:grid-cols-12 md:auto-rows-[300px]">
					<div
						class="group relative flex flex-col justify-end overflow-hidden bg-surface-container-low p-8 md:col-span-8 md:row-span-2 md:p-10"
					>
						<Image
							src={bentoOpera}
							alt={t("home.bento_opera_alt")}
							width={bentoOpera.width}
							height={bentoOpera.height}
							class="absolute inset-0 h-full w-full object-cover opacity-55 transition-transform duration-700 group-hover:scale-105"
							loading="lazy"
							decoding="async"
						/>
						<div
							class="pointer-events-none absolute inset-0 z-1 bg-[linear-gradient(to_top,var(--color-background)_0%,var(--color-background)_8%,color-mix(in_oklab,var(--color-background)_15%,transparent)_22%,transparent_76%)]"
							aria-hidden="true"
						>
						</div>
						<div class="relative z-10">
							<span class="mb-4 block font-headline text-sm uppercase tracking-widest text-secondary"
								>{t("home.bento_guide_label")}</span
							>
							<h3 class="mb-4 font-headline text-3xl font-bold tracking-tighter text-on-surface md:text-4xl">
								{t("home.bento_guide_title")}
							</h3>
							<p class="max-w-md text-on-surface-variant">
								{t("home.bento_guide_body")}
							</p>
						</div>
					</div>

					<div
						class="flex flex-col justify-between border-l-2 border-secondary/40 bg-surface-container p-8 md:col-span-4"
					>
						<span class="material-symbols-outlined text-4xl text-secondary" aria-hidden="true">science</span>
						<div>
							<h3 class="mb-2 font-headline text-2xl font-bold tracking-tighter">{t("home.bento_ai_title")}</h3>
							<p class="text-sm text-on-surface-variant">{t("home.bento_ai_body")}</p>
						</div>
					</div>

					<div class="flex flex-col justify-between bg-surface-container-high p-8 md:col-span-4">
						<div class="mb-4 h-1 w-12 bg-tertiary"></div>
						<div>
							<h3 class="mb-2 font-headline text-2xl font-bold tracking-tighter">{t("home.bento_web_title")}</h3>
							<p class="text-sm text-on-surface-variant">{t("home.bento_web_body")}</p>
						</div>
					</div>

					<div
						class="flex flex-col items-center justify-center bg-primary-container p-8 text-center md:col-span-4 md:p-10"
					>
						<h3 class="mb-6 font-headline text-2xl font-black tracking-tighter text-on-primary-container md:text-3xl">
							{t("home.bento_cta_title")}
						</h3>
						<button
							type="button"
							class="rounded-full bg-surface px-8 py-3 font-headline text-sm font-bold uppercase tracking-tighter text-primary-container transition-colors hover:bg-surface-bright"
						>
							{t("home.cta_call")}
						</button>
					</div>

					<div class="group relative overflow-hidden bg-surface-container-highest p-8 md:col-span-8 md:p-10">
						<div
							class="absolute inset-0 z-10 bg-linear-to-r from-background to-transparent"
							aria-hidden="true"
						>
						</div>
						<Image
							src={bentoKeyboard}
							alt=""
							width={1200}
							height={600}
							class="absolute inset-0 h-full w-full object-cover opacity-30"
							loading="lazy"
							decoding="async"
						/>
						<div class="relative z-20 flex h-full flex-col justify-center">
							<h3 class="mb-4 font-headline text-2xl font-bold tracking-tighter md:text-3xl">
								{t("home.bento_outsourced_title")}
							</h3>
							<p class="max-w-sm text-on-surface-variant">
								{t("home.bento_outsourced_body")}
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="border-border border-t bg-surface-dim px-6 py-24 md:px-10 md:py-32 lg:px-12">
			<div class="mx-auto grid max-w-[1920px] grid-cols-12 gap-6">
				<div class="col-span-12 md:col-span-4">
					<h2 class="mb-4 font-headline text-5xl font-black tracking-tighter text-primary-container md:text-6xl">8</h2>
					<p class="font-headline text-xs uppercase tracking-widest text-on-surface-variant">{t("home.stats_pages")}</p>
				</div>
				<div class="col-span-12 md:col-span-4 md:mt-24">
					<h2 class="mb-4 font-headline text-5xl font-black tracking-tighter text-secondary md:text-6xl">100%</h2>
					<p class="font-headline text-xs uppercase tracking-widest text-on-surface-variant">{t("home.stats_cutting")}</p>
				</div>
				<div class="col-span-12 md:col-span-4 md:mt-12">
					<h2 class="mb-4 font-headline text-5xl font-black tracking-tighter text-tertiary md:text-6xl">0%</h2>
					<p class="font-headline text-xs uppercase tracking-widest text-on-surface-variant">{t("home.stats_bs")}</p>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.material-symbols-outlined {
		font-variation-settings:
			"FILL" 0,
			"wght" 400,
			"GRAD" 0,
			"opsz" 24;
	}
</style>
