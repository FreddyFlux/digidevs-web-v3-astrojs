---
import Layout from "../../layouts/Layout.astro";
import MarketingIcon from "../../components/icons/MarketingIcon";
import { images } from "../../data/remoteImages";
---

<Layout
	title="Competence — digiDEVS"
	description="What we build and how: AI integration, senior talent, Norwegian-led management, and a modern stack."
>
	<main class="relative pt-32">
		<section class="relative overflow-hidden px-8 py-20 md:px-24">
			<div class="misty-glow absolute left-1/4 top-0 -z-10 h-full w-full"></div>
			<div class="mx-auto max-w-7xl">
				<div class="mb-8 inline-block rounded-full border border-outline-variant/15 bg-secondary-container/30 px-4 py-1">
					<span class="font-label text-xs uppercase tracking-widest text-primary-fixed-dim">Technical Excellence</span>
				</div>
				<h1 class="font-headline mb-12 text-7xl font-extrabold tracking-tighter text-white md:text-9xl">Competence</h1>
				<div class="light-streak mb-16 h-px w-full"></div>
				<div class="grid grid-cols-1 items-end gap-16 md:grid-cols-2">
					<p class="font-body max-w-xl text-xl font-light leading-relaxed text-on-surface-variant md:text-2xl">
						Our DNA is built on Norwegian-led precision and global engineering talent. We don't just write code; we architect
						resilient digital ecosystems.
					</p>
					<div class="flex flex-col items-end">
						<span class="font-label mb-4 text-[10px] uppercase tracking-[0.4em] text-white/40">Location & Management</span>
						<span class="font-headline text-2xl font-bold tracking-tight text-white">Oslo | Global Distribution</span>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-surface-container-low px-8 py-32 md:px-24">
			<div class="mx-auto grid max-w-7xl grid-cols-1 gap-6 md:grid-cols-12">
				<div
					class="group relative overflow-hidden rounded-xl bg-surface-container-high p-12 transition-colors duration-500 hover:bg-surface-bright md:col-span-8"
				>
					<div class="absolute -right-20 -top-20 h-80 w-80 rounded-full bg-white/5 blur-[100px]"></div>
					<div class="relative z-10">
						<MarketingIcon name="neurology" className="mb-8 text-4xl text-primary" size={40} />
						<h3 class="font-headline mb-6 text-4xl font-bold text-white">AI Integration</h3>
						<p class="font-body mb-8 max-w-lg text-lg leading-relaxed text-on-surface-variant">
							Moving beyond simple API calls. We implement custom LLM orchestration, vector databases for RAG architectures,
							and predictive analytics that integrate seamlessly into existing enterprise workflows.
						</p>
						<div class="flex flex-wrap gap-3">
							<span class="rounded-full bg-secondary-container/50 px-4 py-1.5 font-label text-xs text-white"
								>LLM Fine-tuning</span
							>
							<span class="rounded-full bg-secondary-container/50 px-4 py-1.5 font-label text-xs text-white"
								>Semantic Search</span
							>
							<span class="rounded-full bg-secondary-container/50 px-4 py-1.5 font-label text-xs text-white"
								>OpenAI / Anthropic</span
							>
						</div>
					</div>
				</div>

				<div
					class="flex flex-col justify-between rounded-xl border border-outline-variant/10 bg-surface-container-highest p-10 md:col-span-4"
				>
					<div>
						<h4 class="font-label mb-12 text-xs uppercase tracking-widest text-white/40">The Team</h4>
						<h3 class="font-headline mb-4 text-3xl font-bold text-white">Senior-Level Development</h3>
						<p class="font-body leading-relaxed text-on-surface-variant">
							Every project is led by developers with over 10 years of experience in high-traffic environments.
						</p>
					</div>
					<div class="mt-12 flex -space-x-4">
						{
							["SD", "ML", "AD"].map((init) => (
								<div class="flex h-12 w-12 items-center justify-center rounded-full border-2 border-surface bg-surface-variant font-label text-xs">
									{init}
								</div>
							))
						}
					</div>
				</div>

				<div class="relative rounded-xl border border-outline-variant/5 bg-surface p-10 md:col-span-5">
					<img
						src={images.competenceNorway}
						alt=""
						width={800}
						height={600}
						class="absolute inset-0 h-full w-full rounded-xl object-cover opacity-20 grayscale"
						loading="lazy"
						decoding="async"
					/>
					<div class="relative z-10">
						<span class="font-label mb-8 block text-xs uppercase tracking-widest text-white/60">Legacy of Quality</span>
						<h3 class="font-headline mb-6 text-3xl font-bold text-white">Norwegian-Led Management</h3>
						<p class="font-body text-on-surface-variant">
							We bring the clinical precision of Scandinavian project management to every engagement. Transparency,
							punctuality, and uncompromising quality are the baselines of our operations.
						</p>
					</div>
				</div>

				<div
					class="flex flex-col items-center gap-12 rounded-xl bg-surface-container-high p-10 md:col-span-7 md:flex-row"
				>
					<div class="flex-1">
						<h3 class="font-headline mb-6 text-3xl font-bold text-white">Modern Stack Mastery</h3>
						<p class="font-body mb-6 text-on-surface-variant">
							We build with technologies designed for the future: Rust, TypeScript, and distributed systems architecture.
						</p>
						<a
							class="group inline-flex items-center font-label text-sm uppercase tracking-widest text-primary"
							href="/blog"
						>
							Full capability list
							<MarketingIcon
								name="arrow_forward"
								className="ml-2 transition-transform group-hover:translate-x-2"
								size={18}
							/>
						</a>
					</div>
					<div class="grid w-full grid-cols-2 gap-4 md:w-48">
						{
							(["cloud", "database", "terminal", "security"] as const).map((name) => (
								<div class="flex aspect-square items-center justify-center rounded-lg bg-surface-variant">
									<MarketingIcon name={name} className="text-3xl text-white/50" size={28} />
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<section class="px-8 py-40 md:px-24">
			<div class="mx-auto max-w-4xl">
				<span class="font-label mb-8 block text-center text-xs uppercase tracking-[0.5em] text-white/30"
					>In-Depth Approach</span
				>
				<h2 class="font-headline mb-24 text-center text-5xl font-bold leading-tight text-white md:text-7xl">
					Engineered for <br />
					<span class="font-light italic">Endurance</span>
				</h2>
				<div class="space-y-32">
					<div class="flex flex-col gap-16 md:flex-row">
						<div class="font-headline text-4xl font-black text-white/10">01</div>
						<div class="flex-1">
							<h4 class="font-headline mb-4 text-2xl font-bold text-white">Architecture First</h4>
							<p class="font-body text-lg leading-relaxed text-on-surface-variant">
								We prioritize scalability and modularity. Before the first line of code is written, our senior architects map
								out data flows and system dependencies to prevent future technical debt.
							</p>
						</div>
					</div>
					<div class="flex flex-col gap-16 md:flex-row">
						<div class="font-headline text-4xl font-black text-white/10">02</div>
						<div class="flex-1">
							<h4 class="font-headline mb-4 text-2xl font-bold text-white">Security by Design</h4>
							<p class="font-body text-lg leading-relaxed text-on-surface-variant">
								Security isn't a feature; it's a foundation. From SOC2 compliance pathways to end-to-end encryption, we
								ensure your data is as resilient as the code that manages it.
							</p>
						</div>
					</div>
					<div class="flex flex-col gap-16 md:flex-row">
						<div class="font-headline text-4xl font-black text-white/10">03</div>
						<div class="flex-1">
							<h4 class="font-headline mb-4 text-2xl font-bold text-white">Continuous Evolution</h4>
							<p class="font-body text-lg leading-relaxed text-on-surface-variant">
								We maintain a dedicated R&amp;D wing that tests emerging AI frameworks and infrastructure patterns,
								ensuring the competence we offer is always on the bleeding edge.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="rounded-t-[4rem] bg-surface-container-highest px-8 py-40 md:px-24">
			<div class="mx-auto max-w-7xl text-center">
				<h2 class="font-headline mb-12 text-4xl font-bold text-white md:text-6xl">Discuss your technical horizon.</h2>
				<button
					type="button"
					class="px-12 py-5 font-label text-sm font-bold uppercase tracking-widest text-on-primary transition-all duration-300 hover:bg-surface-bright active:scale-95 bg-primary"
				>
					Get in Touch
				</button>
			</div>
		</section>
	</main>
</Layout>
