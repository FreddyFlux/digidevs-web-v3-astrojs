---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import DeviconMask from "../../components/icons/DeviconMask.astro";
import MarketingIcon from "../../components/icons/MarketingIcon";
import digidevsValley from "../../assets/digidevs-valley.png";
import { useTranslations } from "../../i18n/utils";
import { absoluteUrl, buildAboutBreadcrumbItems, buildAboutSectionJsonLd } from "../../lib/seo-jsonld";

const t = useTranslations("no");
const siteBase = (import.meta.env.PUBLIC_SITE_URL ?? "https://digidevs.no").replace(/\/$/, "");
const pageUrl = absoluteUrl(siteBase, "no", "/about/competence");
const aboutJsonLd = buildAboutSectionJsonLd(siteBase, "no", {
	pageUrl,
	title: t("competence.meta_title"),
	description: t("competence.meta_description"),
	schemaType: "WebPage",
	breadcrumbItems: buildAboutBreadcrumbItems(siteBase, "no", t, "competence"),
});

const capabilityStackPaths = [
	"react/react-original",
	"astro/astro-plain",
	"typescript/typescript-plain",
	"nodejs/nodejs-plain-wordmark",
	"postgresql/postgresql-plain",
	"python/python-plain",
	"docker/docker-plain",
	"fastapi/fastapi-plain",
	"figma/figma-plain",
	"firebase/firebase-plain",
	"git/git-plain",
	"mongodb/mongodb-plain",
	"reactnative/reactnative-original-wordmark",
	"redis/redis-plain-wordmark",
	"rust/rust-original",
	"sanity/sanity-plain",
	"svelte/svelte-plain",
] as const;
---

<Layout title={t("competence.meta_title")} description={t("competence.meta_description")} lang="no">
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(aboutJsonLd)} />
	<main class="relative pt-32">
		<section class="relative overflow-hidden px-6 py-16 md:px-10 md:py-24">
			<div class="misty-glow absolute left-1/4 top-0 -z-10 h-full w-full"></div>
			<div class="mx-auto max-w-7xl">
				<div class="glass-panel mb-8 inline-flex rounded-full px-4 py-2">
					<span class="font-label text-xs uppercase tracking-widest text-secondary">{t("competence.badge")}</span>
				</div>
				<h1 class="font-headline mb-10 max-w-4xl text-6xl font-bold tracking-editorial text-on-surface md:text-8xl lg:text-9xl">
					{t("competence.heading")}
				</h1>
				<div class="mb-16 max-w-lg">
					<div class="aurora-bar"></div>
				</div>
				<div class="grid grid-cols-1 items-end gap-16 lg:grid-cols-12">
					<p class="font-body max-w-xl text-xl font-light leading-relaxed text-on-surface-variant lg:col-span-7 lg:text-2xl">
						{t("competence.intro")}
					</p>
					<div class="flex flex-col items-start lg:col-span-5 lg:items-end">
						<span class="font-label mb-4 text-[10px] uppercase tracking-[0.4em] text-on-surface-variant"
							>{t("competence.location_label")}</span
						>
						<span class="font-headline text-2xl font-semibold tracking-editorial text-on-surface"
							>{t("competence.location_value")}</span
						>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-surface-container-low px-6 py-24 md:px-10 md:py-32" aria-labelledby="competence-capabilities-heading">
			<h2 id="competence-capabilities-heading" class="sr-only">{t("competence.sr_capabilities")}</h2>
			<div class="mx-auto grid max-w-7xl grid-cols-1 gap-6 md:grid-cols-12">
				<div
					class="group relative overflow-hidden rounded-2xl bg-surface-container p-10 transition-colors duration-500 hover:bg-surface-container-high md:col-span-8 md:p-12"
				>
					<div class="absolute -right-20 -top-20 h-80 w-80 rounded-full bg-secondary/10 blur-[100px]"></div>
					<div class="relative z-10">
						<MarketingIcon name="neurology" className="mb-8 text-4xl text-primary" size={40} />
						<h3 class="font-headline mb-6 text-4xl font-bold tracking-editorial text-on-surface">{t("competence.ai_title")}</h3>
						<p class="font-body mb-8 max-w-lg text-lg leading-relaxed text-on-surface-variant">
							{t("competence.ai_body")}
						</p>
						<div class="flex flex-wrap gap-3">
							<span class="rounded-full bg-secondary/20 px-4 py-1.5 font-label text-xs text-on-secondary-container"
								>{t("competence.tag_llm")}</span
							>
							<span class="rounded-full bg-secondary/20 px-4 py-1.5 font-label text-xs text-on-secondary-container"
								>{t("competence.tag_semantic")}</span
							>
							<span class="rounded-full bg-secondary/20 px-4 py-1.5 font-label text-xs text-on-secondary-container"
								>{t("competence.tag_models")}</span
							>
						</div>
					</div>
				</div>

				<div class="flex flex-col justify-between rounded-2xl bg-surface-container-highest p-10 md:col-span-4">
					<div>
						<p class="font-label mb-12 text-xs uppercase tracking-widest text-on-surface-variant">{t("competence.team_label")}</p>
						<h3 class="font-headline mb-4 text-3xl font-bold tracking-editorial text-on-surface">{t("competence.team_title")}</h3>
						<p class="font-body leading-relaxed text-on-surface-variant">
							{t("competence.team_body")}
						</p>
					</div>
					<div class="mt-12 flex -space-x-4">
						{
							["SD", "ML", "AD"].map((init) => (
								<div class="flex h-12 w-12 items-center justify-center rounded-full bg-surface-container font-label text-xs text-on-surface">
									{init}
								</div>
							))
						}
					</div>
				</div>

				<div class="relative rounded-2xl bg-surface p-10 md:col-span-5">
					<Image
						src={digidevsValley}
						alt=""
						width={digidevsValley.width}
						height={digidevsValley.height}
						sizes="(max-width: 768px) 100vw, 45vw"
						class="absolute inset-0 h-full w-full rounded-2xl object-cover opacity-25 grayscale"
						loading="lazy"
						decoding="async"
						format="avif"
					/>
					<div class="relative z-10">
						<span class="font-label mb-8 block text-xs uppercase tracking-widest text-on-surface-variant"
							>{t("competence.legacy_label")}</span
						>
						<h3 class="font-headline mb-6 text-3xl font-bold tracking-editorial text-on-surface">{t("competence.legacy_title")}</h3>
						<p class="font-body text-on-surface-variant">
							{t("competence.legacy_body")}
						</p>
					</div>
				</div>

				<div
					class="cap-stack-bento flex flex-col items-center gap-12 rounded-2xl bg-surface-container p-10 md:col-span-7 md:flex-row"
				>
					<div class="flex-1">
						<div class="cap-stack-copy">
							<h3 class="font-headline mb-6 text-3xl font-bold tracking-editorial text-on-surface">{t("competence.stack_title")}</h3>
							<p class="font-body mb-6 text-on-surface-variant">
								{t("competence.stack_body")}
							</p>
						</div>
						<details
							id="capability-stack-details"
							class="group/cap [&_summary::-webkit-details-marker]:hidden [&_summary]:list-none"
						>
							<summary
								class="link-tertiary inline-flex cursor-pointer list-none items-center gap-2 font-label text-sm font-medium uppercase tracking-widest outline-none focus-visible:ring-2 focus-visible:ring-secondary-focus focus-visible:ring-offset-2 focus-visible:ring-offset-surface-container"
							>
								{t("competence.stack_toggle")}
							</summary>
							<div class="cap-details-panel">
								<div class="cap-details-panel-inner">
									<div
										class="devicon-enter-stagger mt-6 flex max-w-xs flex-wrap gap-2"
										style={`--devicon-stagger-total: ${capabilityStackPaths.length}`}
									>
										{
											capabilityStackPaths.map((path, index) => (
												<span class="devicon-enter-wrap" style={`--devicon-stagger-index: ${index}`}>
													<DeviconMask path={path} tint="secondary" />
												</span>
											))
										}
									</div>
								</div>
							</div>
						</details>
					</div>
					<div class="grid w-full grid-cols-2 gap-4 md:w-48">
						{
							(["cloud", "database", "terminal", "security"] as const).map((name) => (
								<div class="flex aspect-square items-center justify-center rounded-xl bg-surface-container-high">
									<MarketingIcon name={name} className="text-3xl text-on-surface-variant" size={28} />
								</div>
							))
						}
					</div>
				</div>
			</div>
		</section>

		<section class="px-6 py-32 md:px-10 md:py-40" aria-labelledby="competence-approach-heading">
			<div class="mx-auto max-w-4xl">
				<span class="font-label mb-8 block text-center text-xs uppercase tracking-[0.5em] text-on-surface-variant"
					>{t("competence.approach_kicker")}</span
				>
				<h2
					id="competence-approach-heading"
					class="font-headline mb-24 text-center text-5xl font-bold leading-tight tracking-editorial text-on-surface md:text-7xl"
				>
					{t("competence.approach_heading")} <br />
					<span class="font-body italic text-on-surface-variant">{t("competence.approach_italic")}</span>
				</h2>
				<ol class="m-0 list-none space-y-24 p-0">
					<li class="flex flex-col gap-10 md:flex-row md:gap-16">
						<span class="font-headline shrink-0 text-4xl font-bold text-surface-container-high md:w-24" aria-hidden="true">01</span>
						<div class="flex-1">
							<h3 class="font-headline mb-4 text-2xl font-bold tracking-editorial text-on-surface">{t("competence.step1_title")}</h3>
							<p class="font-body text-lg leading-relaxed text-on-surface-variant">
								{t("competence.step1_body")}
							</p>
						</div>
					</li>
					<li class="flex flex-col gap-10 md:flex-row md:gap-16">
						<span class="font-headline shrink-0 text-4xl font-bold text-surface-container-high md:w-24" aria-hidden="true">02</span>
						<div class="flex-1">
							<h3 class="font-headline mb-4 text-2xl font-bold tracking-editorial text-on-surface">{t("competence.step2_title")}</h3>
							<p class="font-body text-lg leading-relaxed text-on-surface-variant">
								{t("competence.step2_body")}
							</p>
						</div>
					</li>
					<li class="flex flex-col gap-10 md:flex-row md:gap-16">
						<span class="font-headline shrink-0 text-4xl font-bold text-surface-container-high md:w-24" aria-hidden="true">03</span>
						<div class="flex-1">
							<h3 class="font-headline mb-4 text-2xl font-bold tracking-editorial text-on-surface">{t("competence.step3_title")}</h3>
							<p class="font-body text-lg leading-relaxed text-on-surface-variant">
								{t("competence.step3_body")}
							</p>
						</div>
					</li>
				</ol>
			</div>
		</section>

		<section class="rounded-t-[3rem] bg-surface-container-highest px-6 py-32 md:px-10 md:py-40" aria-labelledby="competence-cta-heading">
			<div class="mx-auto max-w-7xl text-center">
				<h2 id="competence-cta-heading" class="font-headline mb-12 text-4xl font-bold tracking-editorial text-on-surface md:text-6xl">
					{t("competence.cta_heading")}
				</h2>
				<a
					href="/contact"
					class="btn-primary-gradient inline-block rounded-xl px-12 py-5 font-label text-sm font-semibold uppercase tracking-widest transition-all hover:brightness-105 active:scale-[0.98]"
				>
					{t("competence.cta_button")}
				</a>
			</div>
		</section>
	</main>

	<script is:inline>
		const CAPABILITY_STAGGER_MS = 100;
		const CAPABILITY_ANIM_MS = 650;
		const CAPABILITY_PANEL_EARLY_MS = 800;

		function restartCapabilityDeviconAnimations(details) {
			if (!details.open) return;
			for (const el of details.querySelectorAll(".devicon-enter-wrap")) {
				el.style.animation = "none";
				void el.offsetWidth;
				el.style.removeProperty("animation");
			}
		}

		function closeCapabilityStackAnimated(details) {
			if (!details.open || details.classList.contains("is-closing-capability")) return;
			const wraps = details.querySelectorAll(".devicon-enter-wrap");
			const n = wraps.length;
			const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
			if (reduced) {
				details.open = false;
				return;
			}
			details.classList.add("is-closing-capability");

			const totalExitMs = (n - 1) * CAPABILITY_STAGGER_MS + CAPABILITY_ANIM_MS;
			const panelEarlyMs = Math.max(0, totalExitMs - CAPABILITY_PANEL_EARLY_MS);
			const finalizeMs = totalExitMs + 40;

			window.setTimeout(() => {
				details.classList.add("is-panel-early-collapse");
			}, panelEarlyMs);

			window.setTimeout(() => {
				details.classList.remove("is-closing-capability");
				details.classList.remove("is-panel-early-collapse");
				details.open = false;
			}, finalizeMs);
		}

		function setupCapabilityStackDetails() {
			const details = document.getElementById("capability-stack-details");
			if (!details || details.dataset.deviconAnimBound === "true") return;
			details.dataset.deviconAnimBound = "true";
			const summary = details.querySelector("summary");
			if (!summary) return;

			details.addEventListener("toggle", () => restartCapabilityDeviconAnimations(details));

			summary.addEventListener(
				"click",
				(e) => {
					if (!details.open) return;
					e.preventDefault();
					closeCapabilityStackAnimated(details);
				},
				true,
			);
		}

		setupCapabilityStackDetails();
		document.addEventListener("astro:page-load", setupCapabilityStackDetails);
	</script>
</Layout>
