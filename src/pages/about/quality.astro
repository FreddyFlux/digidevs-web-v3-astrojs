---
import Layout from "../../layouts/Layout.astro";
import MarketingIcon from "../../components/icons/MarketingIcon";
import { images } from "../../data/remoteImages";
---

<Layout
	title="Quality — digiDEVS"
	description="Norwegian precision, EU standards, GDPR-aware delivery, and boutique craftsmanship — without the Oslo markup."
>
	<main class="mx-auto max-w-7xl px-6 pb-28 pt-36 md:px-10">
		<header class="misty-transition-enter mb-24">
			<div class="mb-16 flex flex-col justify-between gap-10 md:flex-row md:items-end">
				<div>
					<span class="font-label mb-4 block text-xs uppercase tracking-[0.3em] text-secondary">Boutique Engineering</span>
					<h1 class="font-headline text-6xl font-bold tracking-editorial text-on-surface md:text-8xl">Quality</h1>
				</div>
				<div class="max-w-md md:max-w-[42%]">
					<p class="font-body text-lg leading-relaxed text-on-surface-variant">
						We operate at the intersection of Northern precision and Mediterranean artistry, delivering digital products that
						exceed European standards without the prohibitive capital city premiums.
					</p>
				</div>
			</div>
			<div class="group relative h-[min(70vh,614px)] w-full overflow-hidden rounded-2xl bg-surface-container-low">
				<img
					src={images.qualityHero}
					alt="Oslo Opera House architectural detail"
					width={1400}
					height={900}
					sizes="100vw"
					class="h-full w-full object-cover grayscale transition-transform duration-700 group-hover:scale-[1.02]"
					loading="eager"
					decoding="async"
					fetchpriority="high"
				/>
				<div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent opacity-70"></div>
				<div class="absolute bottom-8 left-8">
					<p class="font-label text-xs tracking-widest text-on-surface-variant">EST. 2024 / TRIPLE-AXIS QUALITY</p>
				</div>
			</div>
		</header>

		<section class="mb-28 grid grid-cols-1 gap-6 md:grid-cols-12">
			<div
				class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-surface-container-low p-10 transition-colors duration-500 hover:bg-surface-container md:col-span-7 md:p-12"
			>
				<div class="absolute right-0 top-0 p-8 text-primary/15">
					<MarketingIcon name="architecture" className="text-9xl" size={120} strokeWidth={1} />
				</div>
				<div class="relative z-10">
					<span class="font-label mb-6 block text-sm uppercase tracking-widest text-secondary">01 / The Nordic Core</span>
					<h2 class="font-headline mb-6 text-4xl font-bold tracking-editorial text-on-surface">Norwegian Precision</h2>
					<p class="font-body max-w-md text-lg leading-relaxed text-on-surface-variant">
						Our DNA is rooted in the rigorous standards of Scandinavian engineering. We prioritize structural integrity, clean
						code architecture, and a "function first" philosophy that ensures long-term scalability.
					</p>
				</div>
				<div class="mt-12 flex flex-wrap gap-3">
					<span class="font-label rounded-full bg-surface-container-high px-3 py-1.5 text-[10px] uppercase text-on-surface-variant"
						>Strict QA</span
					>
					<span class="font-label rounded-full bg-surface-container-high px-3 py-1.5 text-[10px] uppercase text-on-surface-variant"
						>Logic First</span
					>
				</div>
			</div>

			<div
				class="relative flex flex-col items-center justify-center overflow-hidden rounded-2xl bg-surface-container-highest p-12 text-center md:col-span-5"
			>
				<div class="mb-8 flex h-24 w-24 items-center justify-center rounded-full bg-surface-container">
					<MarketingIcon name="verified_user" className="text-4xl text-secondary" size={40} />
				</div>
				<h3 class="font-headline mb-4 text-2xl font-bold tracking-editorial text-on-surface">EU Quality Standards</h3>
				<p class="font-body text-sm text-on-surface-variant">
					Fully compliant with GDPR and European accessibility guidelines (WCAG 2.1). We build for the global market from within
					the Union.
				</p>
			</div>

			<div class="group flex flex-col justify-between rounded-2xl bg-surface-container p-12 md:col-span-5">
				<div class="mb-8">
					<span class="font-label mb-6 block text-sm uppercase tracking-widest text-secondary">02 / The Artisan Touch</span>
					<h2 class="font-headline mb-6 text-4xl font-bold tracking-editorial text-on-surface">Croatian Craftsmanship</h2>
					<p class="font-body leading-relaxed text-on-surface-variant">
						Digital soul forged in the Mediterranean. We bring a high-end boutique aesthetic and meticulous attention to UI
						detail, ensuring every interaction feels intentional.
					</p>
				</div>
				<div class="h-48 w-full overflow-hidden rounded-xl grayscale brightness-75 transition-all duration-700 group-hover:brightness-100">
					<img
						src={images.qualityCraft}
						alt=""
						width={800}
						height={400}
						class="h-full w-full object-cover"
						loading="lazy"
						decoding="async"
					/>
				</div>
			</div>

			<div class="flex flex-col justify-center rounded-2xl bg-surface-container-low p-12 md:col-span-7">
				<div class="max-w-xl">
					<h2 class="font-headline mb-8 text-5xl font-bold tracking-editorial text-on-surface">
						Premium output.<br /><span class="text-on-surface-variant">Minus the Oslo markup.</span>
					</h2>
					<p class="font-body mb-12 text-lg leading-relaxed text-on-surface-variant">
						We leverage the efficiency of a distributed boutique model. You get the executive-level quality of a high-end Oslo
						agency, delivered with the cost-agility of a leaner, borderless team.
					</p>
					<div class="grid grid-cols-2 gap-10 pt-8">
						<div>
							<span class="font-label block text-xl font-bold text-on-surface">100%</span>
							<span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Transparency</span>
						</div>
						<div>
							<span class="font-label block text-xl font-bold text-on-surface">0%</span>
							<span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Hidden Fees</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="py-20">
			<div class="flex flex-col gap-16 md:flex-row md:gap-20">
				<div class="md:max-w-sm md:shrink-0">
					<h3 class="font-headline text-3xl font-bold tracking-editorial text-on-surface">The Quality Protocol</h3>
					<p class="font-body mt-4 text-on-surface-variant">Our methodology is a closed-loop system of refinement.</p>
				</div>
				<div class="grid flex-1 grid-cols-1 gap-x-12 gap-y-14 sm:grid-cols-2">
					{
						[
							{
								n: "01",
								t: "Technical Audit",
								d: "Every line of code undergoes a peer-review process based on Norwegian engineering benchmarks.",
							},
							{
								n: "02",
								t: "Visual Stress Test",
								d: "UI components are tested across 12 different viewport scales to ensure responsiveness is absolute.",
							},
							{
								n: "03",
								t: "Accessibility Check",
								d: "Mandatory WCAG 2.1 compliance check for color contrast, screen readers, and keyboard navigation.",
							},
							{
								n: "04",
								t: "Speed Optimization",
								d: "Optimization protocol targeting sub-2s load times on mobile networks to minimize bounce rates.",
							},
						].map((item) => (
							<div class="space-y-4">
								<span class="font-label text-xs text-on-surface-variant">{item.n}</span>
								<h4 class="font-headline text-xl font-bold tracking-editorial text-on-surface">{item.t}</h4>
								<p class="font-body text-sm leading-relaxed text-on-surface-variant">{item.d}</p>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="relative mt-16 flex flex-col items-center overflow-hidden rounded-2xl bg-surface-container p-12 text-center md:p-16">
			<div class="absolute left-0 top-0 h-1 w-full bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
			<h2 class="font-headline mb-6 text-4xl font-bold tracking-editorial text-on-surface">Experience the Balance</h2>
			<p class="font-body mb-12 max-w-lg text-on-surface-variant">
				Ready to elevate your digital presence with European precision and craftsmanship? Let's discuss your next project.
			</p>
			<button
				type="button"
				class="btn-primary-gradient rounded-xl px-10 py-5 font-label text-xs font-semibold uppercase tracking-[0.2em] transition-all hover:brightness-105 active:scale-[0.98]"
			>
				Get in Touch
			</button>
		</section>
	</main>
</Layout>
