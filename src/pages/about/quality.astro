---
import Layout from "../../layouts/Layout.astro";
import MarketingIcon from "../../components/icons/MarketingIcon";
import { images } from "../../data/remoteImages";
---

<Layout
	title="Quality — digiDEVS"
	description="Norwegian precision, EU standards, GDPR-aware delivery, and boutique craftsmanship — without the Oslo markup."
>
	<main class="mx-auto max-w-7xl px-8 pb-24 pt-32">
		<header class="misty-transition-enter mb-32">
			<div class="mb-16 flex flex-col justify-between gap-8 md:flex-row md:items-end">
				<div>
					<span class="font-label mb-4 block text-xs uppercase tracking-[0.3em] text-on-secondary-container"
						>Boutique Engineering</span
					>
					<h1 class="font-headline text-6xl font-extrabold tracking-tighter text-white md:text-8xl">Quality</h1>
				</div>
				<div class="max-w-md">
					<p class="font-body text-lg leading-relaxed text-on-surface-variant">
						We operate at the intersection of Northern precision and Mediterranean artistry, delivering digital products that
						exceed European standards without the prohibitive capital city premiums.
					</p>
				</div>
			</div>
			<div class="group relative h-[614px] w-full overflow-hidden rounded-xl">
				<img
					src={images.qualityHero}
					alt="Oslo Opera House architectural detail"
					width={1400}
					height={900}
					sizes="100vw"
					class="h-full w-full object-cover grayscale transition-transform duration-700 group-hover:scale-105"
					loading="eager"
					decoding="async"
					fetchpriority="high"
				/>
				<div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-transparent opacity-60"></div>
				<div class="absolute bottom-8 left-8">
					<p class="font-label text-xs tracking-widest text-white/40">EST. 2024 / TRIPLE-AXIS QUALITY</p>
				</div>
			</div>
		</header>

		<section class="mb-32 grid grid-cols-1 gap-6 md:grid-cols-12">
			<div
				class="group relative flex flex-col justify-between overflow-hidden rounded-xl bg-surface-container-low p-12 transition-colors duration-500 hover:bg-surface-container md:col-span-7"
			>
				<div class="absolute right-0 top-0 p-8 text-primary/10">
					<MarketingIcon name="architecture" className="text-9xl" size={120} strokeWidth={1} />
				</div>
				<div class="relative z-10">
					<span class="font-label mb-6 block text-sm uppercase tracking-widest text-secondary">01 / The Nordic Core</span>
					<h2 class="font-headline mb-6 text-4xl font-bold text-white">Norwegian Precision</h2>
					<p class="font-body max-w-md text-lg leading-relaxed text-on-surface-variant">
						Our DNA is rooted in the rigorous standards of Scandinavian engineering. We prioritize structural integrity, clean
						code architecture, and a "function first" philosophy that ensures long-term scalability.
					</p>
				</div>
				<div class="mt-12 flex gap-4">
					<span class="font-label rounded-full border border-outline-variant/20 px-3 py-1 text-[10px] uppercase text-white/60"
						>Strict QA</span
					>
					<span class="font-label rounded-full border border-outline-variant/20 px-3 py-1 text-[10px] uppercase text-white/60"
						>Logic First</span
					>
				</div>
			</div>

			<div
				class="relative flex flex-col items-center justify-center overflow-hidden rounded-xl bg-surface-container-highest p-12 text-center md:col-span-5"
			>
				<div class="mb-8 flex h-24 w-24 items-center justify-center rounded-full border border-white/10 bg-white/5">
					<MarketingIcon name="verified_user" className="text-4xl text-white" size={40} />
				</div>
				<h3 class="font-headline mb-4 text-2xl font-bold text-white">EU Quality Standards</h3>
				<p class="font-body text-sm text-on-surface-variant">
					Fully compliant with GDPR and European accessibility guidelines (WCAG 2.1). We build for the global market from within
					the Union.
				</p>
			</div>

			<div
				class="group flex flex-col justify-between rounded-xl bg-surface-container-high p-12 md:col-span-5">
				<div class="mb-8">
					<span class="font-label mb-6 block text-sm uppercase tracking-widest text-secondary">02 / The Artisan Touch</span>
					<h2 class="font-headline mb-6 text-4xl font-bold text-white">Croatian Craftsmanship</h2>
					<p class="font-body leading-relaxed text-on-surface-variant">
						Digital soul forged in the Mediterranean. We bring a high-end boutique aesthetic and meticulous attention to UI
						detail, ensuring every interaction feels intentional.
					</p>
				</div>
				<div class="h-48 w-full overflow-hidden rounded-lg grayscale brightness-50 transition-all duration-700 group-hover:brightness-100">
					<img
						src={images.qualityCraft}
						alt=""
						width={800}
						height={400}
						class="h-full w-full object-cover"
						loading="lazy"
						decoding="async"
					/>
				</div>
			</div>

			<div
				class="relative flex flex-col justify-center rounded-xl border border-outline-variant/5 bg-surface-container-low p-12 md:col-span-7"
			>
				<div class="max-w-xl">
					<h2 class="font-headline mb-8 text-5xl font-extrabold tracking-tight text-white">
						Premium output.<br /><span class="text-white/40">Minus the Oslo markup.</span>
					</h2>
					<p class="font-body mb-12 text-lg leading-relaxed text-on-surface-variant">
						We leverage the efficiency of a distributed boutique model. You get the executive-level quality of a high-end Oslo
						agency, delivered with the cost-agility of a leaner, borderless team.
					</p>
					<div class="grid grid-cols-2 gap-8 border-t border-outline-variant/20 pt-8">
						<div>
							<span class="font-label block text-xl font-bold text-white">100%</span>
							<span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Transparency</span>
						</div>
						<div>
							<span class="font-label block text-xl font-bold text-white">0%</span>
							<span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">Hidden Fees</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="border-t border-outline-variant/10 py-24">
			<div class="flex flex-col gap-16 md:flex-row">
				<div class="md:w-1/3">
					<h3 class="font-headline text-3xl font-bold text-white">The Quality Protocol</h3>
					<p class="font-body mt-4 text-on-surface-variant">Our methodology is a closed-loop system of refinement.</p>
				</div>
				<div class="grid grid-cols-1 gap-x-12 gap-y-16 sm:grid-cols-2 md:w-2/3">
					{
						[
							{
								n: "01",
								t: "Technical Audit",
								d: "Every line of code undergoes a peer-review process based on Norwegian engineering benchmarks.",
							},
							{
								n: "02",
								t: "Visual Stress Test",
								d: "UI components are tested across 12 different viewport scales to ensure responsiveness is absolute.",
							},
							{
								n: "03",
								t: "Accessibility Check",
								d: "Mandatory WCAG 2.1 compliance check for color contrast, screen readers, and keyboard navigation.",
							},
							{
								n: "04",
								t: "Speed Optimization",
								d: "Optimization protocol targeting sub-2s load times on mobile networks to minimize bounce rates.",
							},
						].map((item) => (
							<div class="space-y-4">
								<span class="font-label text-xs text-white/30">{item.n}</span>
								<h4 class="font-headline text-xl font-bold text-white">{item.t}</h4>
								<p class="text-sm leading-relaxed text-on-surface-variant">{item.d}</p>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="relative mt-32 flex flex-col items-center overflow-hidden rounded-xl bg-surface-container p-16 text-center">
			<div class="absolute left-0 top-0 h-px w-full bg-gradient-to-r from-transparent via-primary/20 to-transparent"></div>
			<h2 class="font-headline mb-6 text-4xl font-bold text-white">Experience the Balance</h2>
			<p class="font-body mb-12 max-w-lg text-on-surface-variant">
				Ready to elevate your digital presence with European precision and craftsmanship? Let's discuss your next project.
			</p>
			<button
				type="button"
				class="bg-primary px-10 py-5 font-label text-xs font-bold uppercase tracking-[0.2em] text-on-primary transition-all hover:bg-surface-bright active:scale-95"
			>
				Get in Touch
			</button>
		</section>
	</main>
</Layout>
