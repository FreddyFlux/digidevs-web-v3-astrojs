---
import Layout from "../layouts/Layout.astro";
import MarketingIcon from "../components/icons/MarketingIcon";
import { images } from "../data/remoteImages";
---

<Layout
	title="digiDEVS — Senior-level development, EU quality"
	description="Norwegian-led development studio in Croatia. Web apps, mobile apps, AI-powered products, and team augmentation without Oslo premiums."
>
	<main class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden">
		<div class="absolute inset-0 z-0">
			<div class="absolute inset-0 z-10 bg-gradient-to-b from-background via-transparent to-background"></div>
			<img
				src={images.heroArchitecture}
				alt="Futuristic minimalist architecture at night, misty Nordic atmosphere"
				width={1920}
				height={1080}
				sizes="100vw"
				class="h-full w-full object-cover opacity-40 grayscale"
				loading="eager"
				fetchpriority="high"
				decoding="async"
			/>
			<div class="misty-layer absolute inset-0 opacity-60"></div>
			<div class="absolute bottom-0 left-0 h-1/2 w-full bg-gradient-to-t from-background to-transparent"></div>
		</div>

		<section class="relative z-20 container mx-auto max-w-7xl px-6 pb-24 pt-32 text-center">
			<div
				class="mb-8 inline-flex items-center gap-2 rounded-full border border-outline-variant/15 bg-surface-container-high/50 px-3 py-1 backdrop-blur-sm"
			>
				<span class="h-1.5 w-1.5 animate-pulse rounded-full bg-primary"></span>
				<span class="font-label text-[10px] uppercase tracking-[0.2em] text-white/60">Oslo • Zagreb • Remote</span>
			</div>
			<h1
				class="font-headline mx-auto mb-12 max-w-5xl text-[clamp(2.5rem,8vw,5.5rem)] font-extrabold leading-[0.95] tracking-tighter text-white text-glow"
			>
				Senior-level development. EU quality. <br />
				<span class="font-light italic text-white/20">Without the Oslo price tag.</span>
			</h1>
			<p
				class="font-body mx-auto mb-16 max-w-2xl text-lg leading-relaxed text-on-surface-variant opacity-80 md:text-xl"
			>
				digiDEVS is a Norwegian-led development studio based in Croatia. We build web apps, mobile apps, and AI-powered
				products — and we lead outsourced development teams for companies who need more firepower without the overhead.
			</p>
			<div class="flex flex-col items-center justify-center gap-6 md:flex-row">
				<button
					type="button"
					class="group relative overflow-hidden bg-primary px-10 py-5 font-label font-bold uppercase tracking-widest text-on-primary transition-all duration-500 hover:bg-surface-bright active:scale-95"
				>
					<span class="relative z-10">Start a Project</span>
					<div
						class="absolute inset-0 translate-y-full bg-white/10 transition-transform duration-500 group-hover:translate-y-0"
					>
					</div>
				</button>
				<button
					type="button"
					class="border border-outline-variant/20 px-10 py-5 font-label font-bold uppercase tracking-widest text-white transition-all hover:border-white active:scale-95"
				>
					View Portfolio
				</button>
			</div>
		</section>

		<div
			class="absolute bottom-0 left-1/2 z-10 h-32 w-px -translate-x-1/2 bg-gradient-to-t from-primary to-transparent opacity-30"
		>
		</div>
	</main>

	<section class="bg-background px-8 py-32">
		<div class="mx-auto grid max-w-7xl grid-cols-1 gap-4 md:grid-cols-12">
			<div
				class="group relative flex min-h-[450px] flex-col justify-end overflow-hidden rounded-xl bg-surface-container-low p-12 md:col-span-8"
			>
				<div class="absolute right-0 top-0 p-8 opacity-10 transition-opacity group-hover:opacity-20">
					<MarketingIcon name="terminal" className="text-white" size={120} strokeWidth={1.25} />
				</div>
				<div class="relative z-10">
					<h3 class="font-headline mb-4 text-3xl font-bold text-white">Norwegian Technical Leadership</h3>
					<p class="max-w-md text-on-surface-variant">
						Our architects bring the rigor of Nordic engineering standards to every line of code, ensuring scalability and
						security are never an afterthought.
					</p>
				</div>
			</div>

			<div
				class="group flex flex-col justify-between rounded-xl bg-surface-container-high p-8 transition-all duration-500 hover:bg-surface-container-highest md:col-span-4"
			>
				<MarketingIcon name="speed" className="mb-12 text-primary" size={32} />
				<div>
					<h4 class="font-headline mb-2 text-xl font-bold text-white">High-Velocity Teams</h4>
					<p class="text-sm text-on-surface-variant">
						Rapid deployment of specialized squads integrated directly into your workflow.
					</p>
				</div>
			</div>

			<div
				class="flex flex-col justify-between rounded-xl border border-outline-variant/10 bg-surface-container p-8 md:col-span-4"
			>
				<MarketingIcon name="cloud" className="mb-12 text-white/40" size={32} />
				<div>
					<h4 class="font-headline mb-2 text-xl font-bold text-white">Cloud-Native Focus</h4>
					<p class="text-sm text-on-surface-variant">
						Modern architectures built for the future, leveraging AI and serverless technologies.
					</p>
				</div>
			</div>

			<div
				class="flex flex-col items-center gap-12 rounded-xl border border-white/5 bg-surface-container-lowest p-12 md:col-span-8 md:flex-row"
			>
				<div class="flex-1">
					<span class="font-label mb-4 block text-xs uppercase tracking-widest text-primary/60">Our Reach</span>
					<h3 class="font-headline mb-6 text-4xl font-bold text-white">Bridging Regions.</h3>
					<p class="text-on-surface-variant">
						We combine the project management excellence of Oslo with the deep talent pool of Croatia's booming tech scene.
					</p>
				</div>
				<div class="h-48 w-full overflow-hidden rounded-lg bg-surface-container-high grayscale contrast-125 md:w-64">
					<img
						src={images.fjordTexture}
						alt="Abstract dark fjord water texture"
						width={512}
						height={384}
						sizes="(min-width: 768px) 256px, 100vw"
						class="h-full w-full object-cover"
						loading="lazy"
						decoding="async"
					/>
				</div>
			</div>
		</div>
	</section>
</Layout>
