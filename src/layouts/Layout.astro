---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import type { Locale } from "../i18n/locales";
import { LOCALE_HTML_LANG } from "../i18n/locales";
import { stripLocalePrefixFromPathname } from "../i18n/utils";
import SiteNavbar from "../components/layout/SiteNavbar.astro";
import SiteFooter from "../components/layout/SiteFooter.astro";

interface Props {
	title?: string;
	description?: string;
	/** Comma-separated meta keywords (optional; many crawlers ignore this, but useful internally) */
	keywords?: string;
	lang?: Locale;
	/** Full URL; defaults to current path on PUBLIC_SITE_URL */
	canonicalUrl?: string;
	ogImage?: string;
	ogType?: "website" | "article";
	twitterCard?: "summary" | "summary_large_image";
	noIndex?: boolean;
	/** Per-locale pathnames for hreflang + lang switcher (e.g. translated blog slugs). */
	localeHrefs?: Partial<Record<Locale, string>>;
}

const {
	title = "digiDEVS",
	description = "Norwegian-led development studio. Web apps, mobile apps, and AI-powered products — EU quality without the Oslo price tag.",
	keywords,
	lang = "no",
	canonicalUrl,
	ogImage,
	ogType = "website",
	twitterCard = "summary_large_image",
	noIndex = false,
	localeHrefs,
} = Astro.props;

const pathname = Astro.url.pathname;
const siteBase = (import.meta.env.PUBLIC_SITE_URL ?? "https://digidevs.no").replace(/\/$/, "");
const canonical = canonicalUrl ?? `${siteBase}${pathname}`;

/** Served from `public/digidevs-tagline-og-image.png` */
const DEFAULT_OG_IMAGE_PATH = "/digidevs-tagline-og-image.png";
const defaultOgImageAbsolute = `${siteBase}${DEFAULT_OG_IMAGE_PATH}`;
const defaultOgImageAlt =
	"digiDEVS — Senior-level development. EU quality. Without the Oslo price tag.";

const ogImageFromProp =
	ogImage && (ogImage.startsWith("http://") || ogImage.startsWith("https://"))
		? ogImage
		: ogImage
			? `${siteBase}${ogImage.startsWith("/") ? "" : "/"}${ogImage}`
			: undefined;

const ogImageAbsolute = ogImageFromProp ?? defaultOgImageAbsolute;
const isDefaultOgImage = ogImageAbsolute === defaultOgImageAbsolute;

const strippedPath = stripLocalePrefixFromPathname(pathname);
const pathSuffix = strippedPath === "/" ? "" : strippedPath;
const ogLocale = ({ no: "nb_NO", en: "en_GB", hr: "hr_HR" } as const)[lang] ?? "nb_NO";
const htmlLang = LOCALE_HTML_LANG[lang] ?? lang;

const hreflangNb =
	localeHrefs?.no != null ? `${siteBase}${localeHrefs.no}` : `${siteBase}${pathSuffix || "/"}`;
const hreflangEn =
	localeHrefs?.en != null ? `${siteBase}${localeHrefs.en}` : `${siteBase}/en${pathSuffix}`;
const hreflangHr =
	localeHrefs?.hr != null ? `${siteBase}${localeHrefs.hr}` : `${siteBase}/hr${pathSuffix}`;
const hreflangXDefault = localeHrefs?.no != null ? `${siteBase}${localeHrefs.no}` : `${siteBase}${pathSuffix || "/"}`;

const cookieYesWebsiteKey = import.meta.env.PUBLIC_COOKIEYES_WEBSITE_KEY?.trim() ?? "";
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim() ?? "";
/** GA4 is only served with CookieYes + GCM (see head script order). */
const loadGa4WithGcm = Boolean(cookieYesWebsiteKey && gaMeasurementId);
const loadCookieYesOnly = Boolean(cookieYesWebsiteKey && !gaMeasurementId);
---

<!doctype html>
<html class="dark" lang={htmlLang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#0d1117" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		{keywords && <meta name="keywords" content={keywords} />}
		{noIndex && <meta name="robots" content="noindex, nofollow" />}
		<link rel="canonical" href={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content="digiDEVS" />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:image" content={ogImageAbsolute} />
		{isDefaultOgImage && (
			<>
				<meta property="og:image:width" content="1376" />
				<meta property="og:image:height" content="768" />
				<meta property="og:image:alt" content={defaultOgImageAlt} />
			</>
		)}
		<meta name="twitter:card" content={twitterCard} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageAbsolute} />
		<title>{title}</title>
		{
			loadGa4WithGcm && (
				<>
					<script is:inline>
						window.dataLayer = window.dataLayer || [];
						function gtag() {
							dataLayer.push(arguments);
						}
						gtag("consent", "default", {
							ad_storage: "denied",
							ad_user_data: "denied",
							ad_personalization: "denied",
							analytics_storage: "denied",
							functionality_storage: "denied",
							personalization_storage: "denied",
							security_storage: "granted",
							wait_for_update: 2000,
						});
						gtag("set", "ads_data_redaction", true);
						gtag("set", "url_passthrough", true);
					</script>
					<script
						type="text/javascript"
						id="cookieyes"
						src={`https://cdn-cookieyes.com/client_data/${cookieYesWebsiteKey}/script.js`}
					></script>
					<script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`} />
					<script is:inline define:vars={{ gaMeasurementId }}>
						window.dataLayer = window.dataLayer || [];
						function gtag() {
							dataLayer.push(arguments);
						}
						gtag("js", new Date());
						gtag("config", gaMeasurementId);
					</script>
				</>
			)
		}
		{
			loadCookieYesOnly && (
				<script
					type="text/javascript"
					id="cookieyes"
					src={`https://cdn-cookieyes.com/client_data/${cookieYesWebsiteKey}/script.js`}
				></script>
			)
		}
		<link rel="alternate" hreflang="nb" href={hreflangNb} />
		<link rel="alternate" hreflang="en" href={hreflangEn} />
		<link rel="alternate" hreflang="hr" href={hreflangHr} />
		<link rel="alternate" hreflang="x-default" href={hreflangXDefault} />
		<link
			rel="alternate"
			type="application/rss+xml"
			title="digiDEVS — Blog"
			href={`${siteBase}/rss.xml`}
			hreflang="nb"
		/>
		<link
			rel="alternate"
			type="application/rss+xml"
			title="digiDEVS — Blog (English)"
			href={`${siteBase}/en/rss.xml`}
			hreflang="en"
		/>
		<link
			rel="alternate"
			type="application/rss+xml"
			title="digiDEVS — Blog (Hrvatski)"
			href={`${siteBase}/hr/rss.xml`}
			hreflang="hr"
		/>
		<ClientRouter />
		<slot name="head" />
	</head>
	<body class="selection:bg-primary-container/90 selection:text-on-primary-container">
		<SiteNavbar pathname={pathname} lang={lang} localeHrefs={localeHrefs} />
		<slot />
		<SiteFooter lang={lang} />
		<script is:inline>
			document.addEventListener("astro:after-swap", () => {
				document.querySelectorAll(".aurora-bar").forEach((el) => {
					el.classList.remove("aurora-bar");
					void el.offsetWidth;
					el.classList.add("aurora-bar");
				});
			});
		</script>
		{
			loadGa4WithGcm && (
				<script is:inline define:vars={{ gaMeasurementId }}>
					document.addEventListener("astro:after-swap", () => {
						if (typeof window.gtag === "function") {
							window.gtag("config", gaMeasurementId, {
								page_path: window.location.pathname + window.location.search,
							});
						}
					});
				</script>
			)
		}
	</body>
</html>
