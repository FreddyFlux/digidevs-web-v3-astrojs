{
  "name": "astro-project",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:with-studio": "concurrently -n astro,studio -c cyan,magenta \"pnpm run dev\" \"pnpm run studio\"",
    "build": "astro build",
    "verify:enhancements": "node ./scripts/verify-enhancements.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "seed:sanity": "node --env-file=.env ./scripts/seed-sanity-blog.mjs",
    "studio": "pnpm -C ./sanity-studio run dev",
    "studio:build": "pnpm -C ./sanity-studio run build",
    "studio:deploy": "pnpm -C ./sanity-studio run deploy"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.4",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/jost": "^5.2.8",
    "@portabletext/to-html": "^5.0.2",
    "@portabletext/types": "^4.0.2",
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.1.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.2.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}