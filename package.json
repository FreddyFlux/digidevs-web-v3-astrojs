{
  "name": "astro-project",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:with-studio": "concurrently -n astro,studio -c cyan,magenta \"pnpm run dev\" \"pnpm run studio\"",
    "build": "pnpm -C ./sanity-studio install --frozen-lockfile && node ./scripts/sync-sanity-studio.mjs && astro build",
    "verify:enhancements": "node ./scripts/verify-enhancements.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "seed:sanity": "node --env-file=.env ./scripts/seed-sanity-blog.mjs",
    "studio": "pnpm -C ./sanity-studio run dev",
    "studio:build": "node ./scripts/sync-sanity-studio.mjs",
    "studio:sync": "node ./scripts/sync-sanity-studio.mjs"
  },
  "postinstall": "pnpm -C ./sanity-studio install --frozen-lockfile",
  "dependencies": {
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.4",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/jost": "^5.2.8",
    "@portabletext/to-html": "^5.0.2",
    "@portabletext/types": "^4.0.2",
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.1.1",
    "@sparticuz/chromium": "^148.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "playwright-core": "^1.59.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.2.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "fontaine": "^0.8.0"
  },
  "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1"
}
